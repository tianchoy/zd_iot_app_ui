<template>
	<topNavBar title="充值首页" :show-back="true" @back="goBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<view class="card-info">
			<view class="card-title">
				<text class="title">卡片信息</text>
				<rice-tag :text="cardDetail?.statusStr || '未知'" :round="true" plain-fill size="small" type="success"></rice-tag>
			</view>
			<view class="card-number">{{ cardDetail?.rechargeNo || '未知' }}</view>
			<view class="info-list">
				<view class="info-item" v-if="cardDetail?.pkgName">
					<text class="label">当前套餐</text>
					<text class="value">{{ cardDetail?.pkgName || '未知' }}</text>
				</view>
			</view>
			<view class="flow-box">
				<view class="flow-label">
					<text class="label">流量信息</text>
					<text class="value">已用 {{ cardDetail?.usedFlow || 0 }}GB / 剩余 {{ cardDetail?.unUsedFlow || 0 }}GB / 总流量 {{ cardDetail?.pkgFlow || 0 }}GB</text>
				</view>
				<rice-progress :percentage="percentage" show-text />
			</view>
			<view class="card-bottom">
				<rice-button class="btn mr-24" @click="toMyPackage">卡片套餐</rice-button>
				<rice-button class="btn" @click="toOrderRecord">订单记录</rice-button>
			</view>
		</view>
		<view class="pkg-box">
			<rice-tabs
				v-model="active"
				line-color="#ffffff" 
				:list="tabs" 
				:line-width="0" 
				:title-active-color="'#2563eb'" 
				:title-inactive-color="'#334155'"
				@change="changeTab" 
				:customStyle="{height:'85rpx',padding:'10rpx',border:'1rpx solid #e5edf6'}"
			>
			</rice-tabs>
			<view class="pkg-content">
				<!-- 套餐包列表 -->
				<block v-if="active === 0">
					<view 
						v-for="(item, index) in packageList" 
						:key="item.pkgId || index" 
						class="pkg-card"
						:class="{ 'pkg-card-selected': selectedPackageIndex === index }"
						@click="selectPackage(index)"
					>
						<view class="pkg-info">
							<view class="pkg-name">
								<text class="pkg-title">{{ item.pkgName }}</text>
								<text v-if="item.tag" class="pkg-tag">{{ item.tag }}</text>
							</view>
							<view class="pkg-desc">
								<text class="pkg-icon" v-if="item.pkgFlow">流量 {{ formatFlow(item.pkgFlow) }}</text>
								<text class="pkg-icon" v-if="item.validityPeriod">有效期 {{ item.validityPeriod || '无固定期限' }}天</text>
							</view>
						</view>
						<view class="pkg-price">
							<view class="price-wrapper">
								<text class="price-symbol">¥</text>
								<text class="price-number">{{ item.sellingPrice }}</text>
							</view>
							<view class="price-original" v-if="item.crossedOutPrice && item.crossedOutPrice != item.sellingPrice">
								¥{{ item.crossedOutPrice }}
							</view>
						</view>
					</view>
					<view v-if="packageList.length == 0" class="empty-state">暂无套餐包</view>
				</block>
				<!-- 加油包列表 -->
				<block v-else>
					<view 
						v-for="(item, index) in refillList" 
						:key="item.pkgId || index" 
						class="pkg-card"
						:class="{ 'pkg-card-selected': selectedRefillIndex == index }"
						@click="selectRefill(index)"
					>
						<view class="pkg-info">
							<view class="pkg-name">
								<text class="pkg-title">{{ item.pkgName }}</text>
								<text v-if="item.tag" class="pkg-tag">{{ item.tag }}</text>
							</view>
							<view class="pkg-desc">
								<text class="pkg-icon" v-if="item.pkgFlow">流量 {{ formatFlow(item.pkgFlow) }}</text>
								<text class="pkg-icon" v-if="item.validityPeriod">有效期 {{ item.validityPeriod || '无固定期限' }}天</text>
							</view>
						</view>
						<view class="pkg-price">
							<view class="price-wrapper">
								<text class="price-symbol">¥</text>
								<text class="price-number">{{ item.sellingPrice }}</text>
							</view>
							<view class="price-original" v-if="item.crossedOutPrice && item.crossedOutPrice != item.sellingPrice">
								¥{{ item.crossedOutPrice }}
							</view>
						</view>
					</view>
					<view v-if="refillList.length == 0" class="empty-state">暂无加油包</view>
				</block>
			</view>
		</view>
	</view>
	<rice-popup
		v-model:show="showPopup"
		position="bottom"
		@close="onPopupClose"
	>
		<Payment 
			:amount="currentPrice" 
			@cancel="handleCancelPayment"
			@confirm="handleConfirmPayment"
		/>
	</rice-popup>
	<view class="bottom-box">
		<view class="price-box">
			<text class="price-label">当前套餐金额</text>
			<text class="price-value">¥{{ currentPrice }}</text>
		</view>
		<rice-button type="primary" @click="choosePayment" class="btn">去支付</rice-button>
	</view>
</template>

<script setup lang="uts">
	import { ref, computed } from 'vue';
	import { queryCardDetail } from '@/api/http.uts';
	import type {RechargeData,PkgXcxVo} from '@/api/types'

	import LinearProgress from '@/components/progress.uvue';
	import Payment from '@/components/payment.uvue';
	
	const showPopup = ref<boolean>(false);
	
	// 计算流量使用百分比
	const percentage = computed<number>((): number => {
		const usedFlow = cardDetail.value?.usedPeriod;
		const totalFlow = cardDetail.value?.pkgFlow;
		
		// 如果没有数据，返回0
		if (!usedFlow || !totalFlow) {
			return 0;
		}
		
		const used = parseFloat(usedFlow);
		const total = parseFloat(totalFlow);
		
		// 避免除以0
		if (total === 0) {
			return 0;
		}
		
		// 计算百分比，保留整数
		let percent = (used / total) * 100;
		
		// 限制百分比在0-100之间
		percent = Math.min(100, Math.max(0, percent));
		
		return Math.round(percent);
	});
	
	const active = ref<number>(0);
	const tabs = ref<Array<{name: string}>>([
		{
			name: '套餐包'
		},
		{
			name: '加油包',
		}
	]);
	
	// 套餐包列表
	const packageList = ref<Array<PkgXcxVo>>([]);
	// 加油包列表
	const refillList = ref<Array<PkgXcxVo>>([]);
	
	// 选中的套餐包索引
	const selectedPackageIndex = ref<number>(0);
	// 选中的加油包索引
	const selectedRefillIndex = ref<number>(0);
	
	// 当前价格（根据选中的套餐/加油包计算）
	const currentPrice = computed<string>((): string => {
		if (active.value === 0) {
			const item = packageList.value[selectedPackageIndex.value];
			return item ? item.sellingPrice : '0.00';
		} else {
			const item = refillList.value[selectedRefillIndex.value];
			return item ? item.sellingPrice : '0.00';
		}
	});
	
	// 格式化流量显示（将字节转换为GB）
	const formatFlow = (flow: string | null): string => {
		if (!flow) return '未知';
		const flowBytes = parseFloat(flow);
		if (isNaN(flowBytes)) return '未知';
		
		// 转换为GB（假设流量以字节为单位）
		const flowGB = flowBytes / (1024 * 1024);
		
		if (flowGB >= 1024) {
			return `${(flowGB / 1024).toFixed(2)}TB`;
		} else if (flowGB >= 1) {
			return `${flowGB.toFixed(2)}GB`;
		} else {
			const flowMB = flowBytes / (1024);
			return `${flowMB.toFixed(2)}MB`;
		}
	};
	
	// 根据 pkgCategory 分类套餐和加油包
	const classifyPackages = (packages: Array<PkgXcxVo>) => {
		const packagesList: Array<PkgXcxVo> = [];
		const refillsList: Array<PkgXcxVo> = [];
		
		packages.forEach((item, index) => {
			// pkgCategory: 3为套餐，4为加油包
			if (item.pkgCategory === '3') {
				packagesList.push(item);
			} else if (item.pkgCategory === '4') {
				refillsList.push(item);
			}
		});
		
		packageList.value = packagesList;
		refillList.value = refillsList;
		
		// 重置选中索引
		selectedPackageIndex.value = 0;
		selectedRefillIndex.value = 0;
		
	};
	
	const changeTab = (e: {index: number}) => {
		active.value = e.index;
	}
	
	const selectPackage = (index: number) => {
		selectedPackageIndex.value = index;
	}
	
	const selectRefill = (index: number) => {
		selectedRefillIndex.value = index;
	}
	
	// 选择支付方式
	const choosePayment = () => {
		if (active.value === 0 && packageList.value.length === 0) {
			uni.showToast({
				title: '暂无套餐包可选',
				icon: 'none'
			});
			return;
		}
		if (active.value === 1 && refillList.value.length === 0) {
			uni.showToast({
				title: '暂无加油包可选',
				icon: 'none'
			});
			return;
		}
		showPopup.value = true;
	}
	
	// 取消支付
	const handleCancelPayment = () => {
		showPopup.value = false;
	}
	
	// 确认支付
	const handleConfirmPayment = (e: any) => {
		console.log(e);
		// 获取当前选中的套餐信息
		const currentItem = active.value === 0 
			? packageList.value[selectedPackageIndex.value]
			: refillList.value[selectedRefillIndex.value];
		
		console.log('支付套餐信息:', currentItem);
		// 处理确认逻辑
		showPopup.value = false;
	}
	
	const onPopupClose = () => {
		console.log('弹窗关闭');
	}
	
	const goBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}
	
	// 跳转我的套餐
	const toMyPackage = () => {
		uni.navigateTo({
			url: '/pages/myPkg/myPkg'
		})
	}
	
	// 跳转订单记录
	const toOrderRecord = () => {
		uni.navigateTo({
			url: '/pages/orderRecord/orderRecord'
		})
	}
	
	/** 卡详情 */
	const cardDetail = ref<RechargeData | null>(null)
	
	const getCardDetail = async (cardNumber: string,country: string) => {
		try {
			const res = await queryCardDetail(cardNumber, country,'0')
			if(res.code == 200){
				cardDetail.value = res.data as any
				if (res.data?.pkgXcxVos && res.data.pkgXcxVos.length > 0) {
					classifyPackages(res.data.pkgXcxVos as Array<PkgXcxVo>)
				}
			}
		} catch (error) {
			console.error('获取卡片详情失败:', error)
			uni.showToast({
				title: '获取卡片信息失败',
				icon: 'none'
			})
		}
	}
	
	const cardNumber = ref<string>('')
	const country = ref<string>('')
	onLoad((options: UTSJSONObject) => {
		console.log('options:', options)
		const opt = options as any
		const cardNumberValue = opt.cardNumber
		const countryValue = opt.country
		
		if (cardNumberValue) {
			cardNumber.value = cardNumberValue
			country.value = countryValue ?? ''
			getCardDetail(cardNumber.value, country.value)
		} else {
			console.error('未获取到卡片号码')
			uni.showToast({
				title: '卡片号码不存在',
				icon: 'none'
			})
		}
	})
</script>

