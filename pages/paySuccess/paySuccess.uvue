				color: #ffffff;
				font-size: 80rpx;
				font-weight: 600;
				line-height: 1;
			}
		}
		
		.status-text {
			font-size: 40rpx;
			font-weight: 500;
			color: #333333;
		}
	}
	
	// 卡片容器
	.card-container {
		background-color: #ffffff;
		border: 1px solid #e7edf5;
		border-radius: 24rpx;
		padding: 32rpx;
		margin-bottom: 60rpx;
		box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
	}
	
	// 信息行
	.info-row {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		padding: 24rpx 0;
		border-bottom: 1rpx solid #f0f0f0;

		
		.label {
			font-size: 24rpx;
			color: #64748b;
			flex-shrink: 0;
			width: 160rpx;
		}
		
		.value {
			font-size: 25rpx;
			color: #0f172a;
			font-weight: bold;
			text-align: right;
			flex: 1;
		}

		.amount {
			font-weight: bold;
			color: #ff6b00;
		}
	}
	
	// 按钮区域
	.button-section {
		display: flex;
		flex-direction: column;
		
		.action-btn {
			width: 100%;
			height: 88rpx;
			line-height: 88rpx;
			border-radius: 44rpx;
			font-size: 30rpx;
			font-weight: 500;
			text-align: center;
			border: none;
			padding: 0;
			
			&::after {
				border: none;
			}
		}
		
		.primary-btn {
			background-color: #07c160;
			color: #ffffff;
		}
		
		.secondary-btn {
			background-color: #ffffff;
