<template>
	<topNavBar title="支付结果" :show-back="false" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<!-- 成功状态区域 -->
		<view class="status-section">
			<view class="success-icon">
				<text class="checkmark">✓</text>
			</view>
			<text class="status-text">支付成功</text>
		</view>

		<!-- 卡片详情区域 -->
		<view class="card-container">
			<!-- 卡号 -->
			<view class="info-row" v-if="orderDetail.rechargeNo">
				<text class="label">卡号</text>
				<text class="value">{{orderDetail.rechargeNo}}</text>
			</view>
			
			<!-- ICCID -->
			<view class="info-row" v-if="orderDetail.iccid">
				<text class="label">ICCID</text>
				<text class="value">{{orderDetail.iccid}}</text>
			</view>
			
			<!-- 订单编号 -->
			<view class="info-row" v-if="orderDetail.orderNo">
				<text class="label">订单编号</text>
				<text class="value">{{orderDetail.orderNo}}</text>
			</view>
			
			<!-- 套餐名称 -->
			<view class="info-row" v-if="orderDetail.pkgName">
				<text class="label">套餐名称</text>
				<text class="value">{{orderDetail.pkgName}}</text>
			</view>
			
			<!-- 套餐类型 -->
			<view class="info-row" v-if="orderDetail.pkgType">
				<text class="label">套餐类型</text>
				<text class="value">{{orderDetail.pkgType}}</text>
			</view>
			
			<!-- 支付方式 -->
			<!-- #ifndef MP-WEIXIN -->
			<view class="info-row" v-if="orderDetail.payType">
				<text class="label">支付方式</text>
				<text class="value">{{orderDetail.payType}}</text>
			</view>
			<!-- #endif -->
			
			<!-- 支付金额 (突出显示) -->
			<view class="info-row" v-if="orderDetail.payAmount">
				<text class="label">支付金额</text>
				<text class="value amount">￥{{orderDetail.payAmount}}</text>
			</view>

			<view class="info-row" v-if="orderDetail.payTime">
				<text class="label">支付时间</text>
				<text class="value">{{orderDetail.payTime}}</text>
			</view>
		</view>
		
		<!-- 按钮区域 -->
		<view class="button-section">
			<button class="action-btn primary-btn mb-24" @click="handleViewOrder">查看订单</button>
			<button class="action-btn secondary-btn" @click="handleBackCard">返回卡片详情</button>
		</view>
	</view>
</template>

<script setup lang="uts">
	import {queryOrderSuccess} from '@/api/http'
	const orderId = ref<string>('')
	const payChannelId = ref<string>('')
	const orderDetail = ref<any>({})
	// 查看订单点击处理
	const handleViewOrder = () => {
		// 平台兼容处理
		// #ifdef APP
		console.log('查看订单APP');
		// #endif
		// #ifdef MP-WEIXIN
		console.log('查看订单MP-WEIXIN');
		uni.reLaunch({
			url: `/pages/orderDetail/orderDetail?orderNo=${orderId.value}`
		})
		// #endif
		// #ifdef H5
		console.log('查看订单H5');
		// #endif
	}
	
	// 返回卡片详情点击处理
	const handleBackCard = () => {
		// 平台兼容处理
		// #ifdef APP
		console.log('返回卡片详情APP');
		// #endif
		// #ifdef MP-WEIXIN
		console.log('返回卡片详情MP-WEIXIN');
		uni.reLaunch({
			url: `/pages/cardDetail/cardDetail?cardNumber=${orderId.value}`
		})
		// #endif
		// #ifdef H5
		console.log('返回卡片详情H5');
		// #endif
	}

	const getOrderDetail = async () => {
		const res = await queryOrderSuccess(orderId.value,payChannelId.value)
		if(res.code == 200){
			console.log('订单详情:',res)
			orderDetail.value = res.data
		}
	}

	onLoad((options)=>{
		console.log('orderId:',options)	
		orderId.value = options.orderId ?? ''
		payChannelId.value = options.payChannelId ?? ''
		getOrderDetail()
	})
</script>

