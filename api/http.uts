// api/http.uts

import { http, type ApiResponse } from '@/uni_modules/m-unix/components/m-tools/Request.uts'


export type LoginData = {
  token: string
  refreshToken: string
  userId: number
  nickname: string
}

// 显式指定泛型类型和返回类型
export const card_detail = (id: string, countryCode: string, withToken: boolean = true): Promise<ApiResponse<LoginData>> => {
  return http.get(
    '/app/card/info/' + id + '/' + countryCode,
    null,
    { withToken }
  ) as Promise<ApiResponse<LoginData>>
}