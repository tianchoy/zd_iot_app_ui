<template>
	<view class="m-clipboard" @tap="handleCopy">
		<slot></slot>
	</view>
</template>

<script lang="uts">
	import { copyToClipboard } from '../m-tools/Ut.uts'
	export default {
		name: 'mClipboard',
		emits: ['copy'],
		props: {
			text: {
				type: String,
				default: ''
			}
		},
		methods: {
			handleCopy() {
				if (!this.text) {
					return
				}
				const t = this.text as string
				copyToClipboard(t, (success: boolean) => {
					this.$emit('copy', {
						text: this.text,
						success: success
					})
				})
			}
		}
	};
</script>

<style scoped lang="scss">
.m-clipboard {
	width: 100%;
}
</style>
