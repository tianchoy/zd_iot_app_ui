<template>
	<view>
		<view v-if="isOpen" class="m-dialog" :style="{background:backgroundColor,borderRadius:radius}"
			@tap.stop="stopEvent">
			<view class="m-dialog__hd" v-if="title !== ''">
				<view class="m-dialog__title" :style="{color:titleColor}">{{title}}
					<slot name="title"></slot>
				</view>
			</view>
			<view
				class="m-dialog__bd"
				:class="{ 'm-dialog__bd--no-title': title === '' }"
				:style="{ color: contentColor }"
			>
				<slot name="content">{{ content }}</slot>
			</view>
			<view class="m-dialog__ft">
				<template v-if="effectiveButtons.length > 0">
					<view v-for="(item,index) in effectiveButtons" :key="index"
						:style="{color:item.color || '#333'}" class="m-dialog__btn" @tap="buttonTap(index)">
						{{item.text}}</view>
				</template>
				<slot name="footer" v-else></slot>
			</view>
		</view>
		<view v-if="mask && isOpen" @tap="close" class="m-dialog__mask"></view>
	</view>
</template>

<script lang="uts">
	export default {
		name: 'mDialog',
		emits: ['click', 'close', 'confirm', 'cancel', 'update:show', 'update:visible'],
		props: {
			title: {
				type: String as unknown as PropType<string>,
				default: ''
			},
			// 正文纯文本（与 content 插槽二选一，插槽优先）
			content: {
				type: String as unknown as PropType<string>,
				default: ''
			},
			// 为 true 且未传 buttons 时，使用「取消 / 确定」并触发 cancel、confirm
			showCancel: {
				type: Boolean,
				default: false
			},
			maskClosable: {
				type: Boolean,
				default: true
			},
			mask: {
				type: Boolean,
				default: true
			},
			show: {
				type: Boolean,
				default: false
			},
			// 与 show 等价，便于与演示页命名统一
			visible: {
				type: Boolean,
				default: false
			},
			buttons: {
				type: Array as PropType<Array<{ text : string; color ?: string }>>,
				default() {
					return []
				}
			},
			backgroundColor: {
				type: String as unknown as PropType<string>,
				default: '#fff'
			},
			radius: {
				type: String as unknown as PropType<string>,
				default: '12px'
			},
			titleColor: {
				type: String as unknown as PropType<string>,
				default: '#333'
			},
			contentColor: {
				type: String as unknown as PropType<string>,
				default: '#999'
			}
		},
		computed: {
			isOpen(): boolean {
				return this.show || this.visible
			},
			effectiveButtons(): Array<{ text : string; color ?: string }> {
				const list = this.buttons as Array<{ text : string; color ?: string }>
				if (this.showCancel && list.length === 0) {
					return [{ text: '取消' }, { text: '确定', color: '#586c94' }]
				}
				return list
			},
			useDefaultConfirmPair(): boolean {
				return this.showCancel && (this.buttons as any[]).length === 0
			}
		},
		methods: {
			buttonTap(index : number) {
				const item = this.effectiveButtons[index]
				this.$emit('click', {
					index,
					item
				})
				if (this.useDefaultConfirmPair) {
					if (index === 0) {
						this.$emit('cancel')
					} else if (index === 1) {
						this.$emit('confirm')
					}
				}
				// 底部按钮点击后关闭弹窗，与遮罩关闭一致，便于 v-model:show / v-model:visible 同步
				this.$emit('update:show', false)
				this.$emit('update:visible', false)
			},

			close() {
				if (!this.maskClosable) return;
				this.$emit('close', {});
				this.$emit('update:show', false)
				this.$emit('update:visible', false)
			},

			stopEvent() { }
		}
	}
</script>

<style lang="scss" scoped>
	.m-dialog {
		position: fixed;
		z-index: 5000;
		top: 50%;
		left: 16px;
		right: 16px;
		transform: translateY(-50%);
		text-align: center;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		max-height: 90%;
		align-items: center;
	}

	.m-dialog__hd {
		padding: 32px 24px 16px;
		align-self: stretch;
		width: 100%;
		box-sizing: border-box;
	}

	.m-dialog__title {
		font-weight: 700;
		font-size: 17px;
		line-height: 1.4
	}

	.m-dialog__bd {
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		padding: 0 24px;
		margin-bottom: 32px;
		font-size: 15px;
		line-height: 1.4;
		word-wrap: break-word;
		-webkit-hyphens: auto;
		hyphens: auto;
		align-self: stretch;
		width: 100%;
		box-sizing: border-box;
	}

	/* 无标题时正文区域水平、垂直居中（短文案在可视区域内居中；过长仍可滚动） */
	.m-dialog__bd--no-title {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 32px 24px 24px;
		margin-bottom: 32px;
		min-height: 88px;
	}


	.m-dialog__ft {
		display: flex;
		position: relative;
		line-height: 56px;
		min-height: 56px;
		font-size: 17px;
		width: 100%;
		flex-direction: row;
	}

	.m-dialog__ft:after {
		content: " ";
		position: absolute;
		left: 0;
		top: 0;
		right: 0;
		height: 1px;
		border-top: 1px solid rgba(0, 0, 0, .1);
		transform-origin: 0 0;
		transform: scaleY(.5)
	}

	.m-dialog__btn {
		display: block;
		flex: 1;
		font-weight: 700;
		text-decoration: none;
		-webkit-tap-highlight-color: rgba(0, 0, 0, 0);
		position: relative;
		text-align: center;
	}

	.m-dialog__btn:active {
		background-color: #ECECEC
	}

	.m-dialog__btn:first-child::after {
		width: 0;
		border-left: 0;
	}

	.m-dialog__btn::after {
		content: " ";
		position: absolute;
		left: 0;
		top: 0;
		width: 1px;
		bottom: 0;
		border-left: 1px solid rgba(0, 0, 0, .1);
		transform-origin: 0 0;
		transform: scaleX(.5)
	}

	.m-dialog__mask {
		position: fixed;
		z-index: 4000;
		top: 0;
		right: 0;
		left: 0;
		bottom: 0;
		background: rgba(0, 0, 0, .6);
		opacity: 1;
		transform: scale3d(1, 1, 1);
		transition: all .2s ease-in
	}
</style>