<template>
	<topNavBar title="中导云卡登录" :show-back="false" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<image src="/static/defaultAvator.png" class="logo"></image>
		<view class="login-btn">
			<button 
			open-type="getPhoneNumber" 
			type="primary" 
			plain="true"	
			@getphonenumber="handleGetPhoneNumber">
			个人用户登录
			</button>
		</view>
		<view class="no-login">
			<view class="no-login-text">暂不登录</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import {login} from '@/api/http.uts'
	const wxGetPhoneLogin = ref('')
	const handleGetPhoneNumber = (res: UTSJSONObject) => {
		console.log('获取手机号:', res)
	}

	//登录
	const userLoginByOpenid = async (codes: string) => {
		const res = await login({
			xcxCode: codes,
			isLogin: '1',
		})
		console.log('登录:', res)
	}

	//获取 code
	const code = ref<string>('')
	const getCode = () => {
		uni.login({
			success: (res) => {
				code.value = res.code
				userLoginByOpenid(res.code);
			}
		})
	}
	onLoad((options) => {
		console.log(options)
		if(options['wxGetPhoneLogin'] != null){
			wxGetPhoneLogin.value = options['wxGetPhoneLogin'] as string
		}
		getCode();
	})
</script>

