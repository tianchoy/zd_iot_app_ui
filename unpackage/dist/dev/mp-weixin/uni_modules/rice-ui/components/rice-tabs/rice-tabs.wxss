.rice-tabs.data-v-c0441e19 {
  display: flex;
  flex-direction: row;
  border-radius: 24rpx;
  background-color: #f3f7fb;
  border: 1rpx solid #e5edf6;
}
.rice-tabs__scroll.data-v-c0441e19 {
  flex-direction: row;
  height: 100%;
  flex: 1;
}
.rice-tabs__scrollmp.data-v-c0441e19 {
  position: relative;
  flex: 1;
  height: 100%;
  flex-direction: row;
  align-items: center;
  overflow: visible;
}
.rice-tabs__item.data-v-c0441e19 {
  flex: 1;
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-grow: 1;
  flex-shrink: 0;
  overflow: visible;
  height: 100%;
}
.rice-tabs__item__text.data-v-c0441e19 {
  transition: color 0.3s;
  font-size: 15px;
  color: var(--rice-text-color-2);
}
.rice-tabs__item__active.data-v-c0441e19 {
  background-color: #fff;
  border-radius: 24rpx;
  flex: 1;
  padding: 12rpx 0;
  text-align: center;
}
.rice-tabs__item__disabled.data-v-c0441e19 {
  color: var(--rice-tabs-disabled-text-color);
}
.rice-tabs__item__line.data-v-c0441e19 {
  position: absolute;
  z-index: 1;
  bottom: 2px;
  left: 50%;
  border-radius: 100px;
  transform: translateX(-50%);
  transition-property: width;
  transition-duration: 250ms;
  width: 0px;
  height: 3px;
  background-color: var(--rice-primary-color);
}
.rice-tabs--shrink.data-v-c0441e19 {
  padding: 0 8px;
  flex: none;
}
.rice-tabs__indicator.data-v-c0441e19 {
  position: absolute;
  z-index: 1;
  bottom: 2px;
  left: 0px;
  border-radius: 100px;
  transition-property: transform, width;
  transition-duration: 250ms;
  width: 20px;
  height: 3px;
  background-color: var(--rice-primary-color);
}
.rice-tabs__indicator--animate.data-v-c0441e19 {
  opacity: 0;
}