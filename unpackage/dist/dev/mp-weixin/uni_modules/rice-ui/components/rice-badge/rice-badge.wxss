.rice-badge.data-v-9ecbe9e4 {
  position: relative;
  overflow: visible;
  width: -webkit-fit-content;
  width: fit-content;
}
.rice-badge__content.data-v-9ecbe9e4 {
  padding: 0px 4px;
  min-width: 16px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border-radius: 100px;
  border: 1px solid #fff;
  background-color: var(--rice-error-color);
}
.rice-badge__content__text.data-v-9ecbe9e4 {
  font-size: 12px;
  color: #fff;
  white-space: nowrap;
}
.rice-badge--fixed.data-v-9ecbe9e4 {
  position: absolute;
  z-index: 99;
}
.rice-badge--dot.data-v-9ecbe9e4 {
  height: 12px;
  width: 12px;
  border-radius: 12px;
  padding: 0;
  min-width: 0;
}
.rice-badge--top-left.data-v-9ecbe9e4 {
  top: 0;
  left: 0;
  transform: translate(-50%, -50%);
}
.rice-badge--top-right.data-v-9ecbe9e4 {
  top: 0;
  right: 0;
  transform: translate(50%, -50%);
}
.rice-badge--bottom-left.data-v-9ecbe9e4 {
  bottom: 0;
  left: 0;
  transform: translate(-50%, 50%);
}
.rice-badge--bottom-right.data-v-9ecbe9e4 {
  bottom: 0;
  right: 0;
  transform: translate(50%, 50%);
}
.rice-badge--primary.data-v-9ecbe9e4 {
  background-color: var(--rice-primary-color);
}
.rice-badge--success.data-v-9ecbe9e4 {
  background-color: var(--rice-success-color);
}
.rice-badge--warning.data-v-9ecbe9e4 {
  background-color: var(--rice-warning-color);
}
.rice-badge--error.data-v-9ecbe9e4 {
  background-color: var(--rice-error-color);
}