.m-fab__mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.2);
}
.m-fab__subs {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-bottom: 24rpx;
}
.m-fab__sub {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  margin-bottom: 16rpx;
}
.m-fab__sub-img {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}
.m-fab__sub-text {
  font-size: 28rpx;
}
.m-fab__main {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.m-fab__main--drag {
  /* 减少拖动时误触页面滚动（H5 等端） */
}

/* 避免图标/文字子节点成为触摸目标，导致 touchmove 无法稳定派发到主按钮（H5 常见） */
.m-fab__main--drag-pass > .m-fab__main-child {
  pointer-events: none;
}
.m-fab__plus {
  font-size: 64rpx;
  line-height: 1;
}