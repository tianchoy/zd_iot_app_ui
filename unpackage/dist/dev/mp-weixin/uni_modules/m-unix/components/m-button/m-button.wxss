/* 文章场景相关 */
.m-button__wrap.data-v-bb5b2fb2 {
  position: relative;
  overflow: visible;
  box-sizing: border-box;
}

/* button start*/
.m-btn.data-v-bb5b2fb2 {
  width: 100%;
  position: relative;
  border: 0 !important;
  box-sizing: border-box;
  border-radius: 6rpx;
  padding-left: 0;
  padding-right: 0;
  overflow: visible;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.m-btn__inner.data-v-bb5b2fb2 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  /* 子项间距：避免使用 * + *（微信小程序 WXSS 不支持通用选择器 *） */
}
.m-btn--loading.data-v-bb5b2fb2 {
  pointer-events: none;
}
.m-btn.data-v-bb5b2fb2::after {
  border: 0;
}
.m-btn__flex-1.data-v-bb5b2fb2 {
  flex: 1;
}

/* 镂空边框：与内容区同尺寸，避免 200% + scale(0.5) 在部分端右侧被裁切 */
.m-button__border.data-v-bb5b2fb2 {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  border-radius: 6rpx;
  border: 1px solid transparent;
  pointer-events: none;
}
.m-text-bold.data-v-bb5b2fb2 {
  font-weight: bold;
}
.m-dark-disabled.data-v-bb5b2fb2 {
  opacity: 0.6 !important;
  color: #fafbfc !important;
}
.m-dark-disabled-outline.data-v-bb5b2fb2 {
  opacity: 0.5 !important;
}
.m-gray-disabled.data-v-bb5b2fb2 {
  background: #f3f3f3 !important;
  color: #919191 !important;
  box-shadow: none;
}

/*圆角 */
.m-fillet.data-v-bb5b2fb2 {
  border-radius: 220rpx !important;
}
.m-fillet.data-v-bb5b2fb2::after {
  border-radius: 220rpx !important;
}
.m-outline-fillet.data-v-bb5b2fb2 {
  border-radius: 220rpx !important;
}
.m-outline-fillet.data-v-bb5b2fb2::after {
  border-radius: 220rpx !important;
}

/*平角*/
.m-rightAngle.data-v-bb5b2fb2 {
  border-radius: 0 !important;
}
.m-rightAngle.data-v-bb5b2fb2::after {
  border-radius: 0 !important;
}
.m-outline-rightAngle.data-v-bb5b2fb2 {
  border-radius: 0 !important;
}
.m-outline-rightAngle.data-v-bb5b2fb2::after {
  border-radius: 0 !important;
}
.m-btn__link.data-v-bb5b2fb2::after {
  border: 0 !important;
}