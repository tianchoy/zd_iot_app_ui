.m-loading.data-v-288d639e {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* 圆点使用 currentColor，与 color 属性一致 */
  color: var(--0e6d0252);
}
.m-loading.m-loading--full.data-v-288d639e {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background-color: rgba(255, 255, 255, 0.8);
}
.m-loading .m-loading__spinner.data-v-288d639e {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 40rpx;
  /* 圆点间距：避免 * + *（微信小程序 WXSS 不支持通用选择器 *） */
  gap: 16rpx;
}
.m-loading .m-loading__spinner .m-loading__dot.data-v-288d639e {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: currentColor;
}
.m-loading .m-loading__spinner .m-loading__dot.data-v-288d639e:nth-child(1) {
  animation: m-loading-288d639e 1s infinite ease-in-out 0s;
}
.m-loading .m-loading__spinner .m-loading__dot.data-v-288d639e:nth-child(2) {
  animation: m-loading-288d639e 1s infinite ease-in-out 0.2s;
}
.m-loading .m-loading__spinner .m-loading__dot.data-v-288d639e:nth-child(3) {
  animation: m-loading-288d639e 1s infinite ease-in-out 0.4s;
}
.m-loading .m-loading__spinner.m-loading__spinner--anim.data-v-288d639e {
  animation-play-state: running;
}
.m-loading .m-loading__text.data-v-288d639e {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--0e6d0252);
}
@keyframes m-loading-288d639e {
0%, 80%, 100% {
    transform: scale(0);
}
40% {
    transform: scale(1);
}
}