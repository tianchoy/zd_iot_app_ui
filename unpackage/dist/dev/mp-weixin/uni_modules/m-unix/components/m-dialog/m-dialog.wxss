.m-dialog.data-v-16aa4b6b {
  position: fixed;
  z-index: 5000;
  top: 50%;
  left: 16px;
  right: 16px;
  transform: translateY(-50%);
  text-align: center;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  max-height: 90%;
  align-items: center;
}
.m-dialog__hd.data-v-16aa4b6b {
  padding: 32px 24px 16px;
  align-self: stretch;
  width: 100%;
  box-sizing: border-box;
}
.m-dialog__title.data-v-16aa4b6b {
  font-weight: 700;
  font-size: 17px;
  line-height: 1.4;
}
.m-dialog__bd.data-v-16aa4b6b {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 24px;
  margin-bottom: 32px;
  font-size: 15px;
  line-height: 1.4;
  word-wrap: break-word;
  -webkit-hyphens: auto;
  hyphens: auto;
  align-self: stretch;
  width: 100%;
  box-sizing: border-box;
}

/* 无标题时正文区域水平、垂直居中（短文案在可视区域内居中；过长仍可滚动） */
.m-dialog__bd--no-title.data-v-16aa4b6b {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 32px 24px 24px;
  margin-bottom: 32px;
  min-height: 88px;
}
.m-dialog__ft.data-v-16aa4b6b {
  display: flex;
  position: relative;
  line-height: 56px;
  min-height: 56px;
  font-size: 17px;
  width: 100%;
  flex-direction: row;
}
.m-dialog__ft.data-v-16aa4b6b:after {
  content: " ";
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 1px;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
  transform-origin: 0 0;
  transform: scaleY(0.5);
}
.m-dialog__btn.data-v-16aa4b6b {
  display: block;
  flex: 1;
  font-weight: 700;
  text-decoration: none;
  -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
  position: relative;
  text-align: center;
}
.m-dialog__btn.data-v-16aa4b6b:active {
  background-color: #ECECEC;
}
.m-dialog__btn.data-v-16aa4b6b:first-child::after {
  width: 0;
  border-left: 0;
}
.m-dialog__btn.data-v-16aa4b6b::after {
  content: " ";
  position: absolute;
  left: 0;
  top: 0;
  width: 1px;
  bottom: 0;
  border-left: 1px solid rgba(0, 0, 0, 0.1);
  transform-origin: 0 0;
  transform: scaleX(0.5);
}
.m-dialog__mask.data-v-16aa4b6b {
  position: fixed;
  z-index: 4000;
  top: 0;
  right: 0;
  left: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  opacity: 1;
  transform: scale3d(1, 1, 1);
  transition: all 0.2s ease-in;
}