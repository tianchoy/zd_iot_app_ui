}
.m-popup .m-popup__content.m-popup--fullscreen.data-v-852cc016 {
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  max-height: 100%;
  background-color: transparent;
  opacity: 0;
  transform: scale(0.96);
  border-radius: 0;
  overflow: hidden;
}
.m-popup .m-popup__content.m-popup--fullscreen.m-popup__content--show.data-v-852cc016 {
