.m-popup.data-v-852cc016 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}
.m-popup .m-popup__content.data-v-852cc016 {
  position: absolute;
  background-color: #ffffff;
  box-sizing: border-box;
  pointer-events: auto;
  overflow-y: auto;
  transition-property: transform, opacity;
  transition-timing-function: cubic-bezier(0.25, 0.8, 0.25, 1);
  /* 全屏层：弹屏广告、大图引导等；插槽区无默认内边距，由业务铺满 */
}
.m-popup .m-popup__content.m-popup--bottom.data-v-852cc016 {
  bottom: var(--uni-safe-area-inset-bottom, 0px);
  left: 0;
  width: 100%;
  transform: translateY(100%);
}
.m-popup .m-popup__content.m-popup--bottom.m-popup__content--show.data-v-852cc016 {
  transform: translateY(0);
}
.m-popup .m-popup__content.m-popup--bottom.m-popup--round.data-v-852cc016 {
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}
.m-popup .m-popup__content.m-popup--center.data-v-852cc016 {
  top: 50%;
  left: 50%;
  width: auto;
  min-width: 520rpx;
  max-width: 86%;
  opacity: 0;
  transform: translate(-50%, -46%) scale(0.94);
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.12);
  overflow-x: hidden;
  /* 居中弹层：内边距与底部/侧边区分，避免插槽内容贴边 */
}
.m-popup .m-popup__content.m-popup--center.m-popup__content--show.data-v-852cc016 {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}
.m-popup .m-popup__content.m-popup--center.m-popup--round.data-v-852cc016 {
  border-radius: 20rpx;
}
.m-popup .m-popup__content.m-popup--center .m-popup__content-inner.data-v-852cc016 {
  padding: 44rpx 48rpx 40rpx;
}
.m-popup .m-popup__content.m-popup--center.m-popup--closeable .m-popup__content-inner.data-v-852cc016 {
  padding-top: 56rpx;
}
.m-popup .m-popup__content.m-popup--top.data-v-852cc016 {
  top: var(--uni-safe-area-inset-top, 0px);
  left: 0;
  width: 100%;
  transform: translateY(-100%);
}
.m-popup .m-popup__content.m-popup--top.m-popup__content--show.data-v-852cc016 {
  transform: translateY(0);
}
.m-popup .m-popup__content.m-popup--top.m-popup--round.data-v-852cc016 {
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}
.m-popup .m-popup__content.m-popup--left.data-v-852cc016 {
  top: var(--uni-safe-area-inset-top, 0px);
  left: 0;
  bottom: var(--uni-safe-area-inset-bottom, 0px);
  width: 70%;
  max-width: 600rpx;
  transform: translateX(-100%);
}
.m-popup .m-popup__content.m-popup--left.m-popup__content--show.data-v-852cc016 {
  transform: translateX(0);
}
.m-popup .m-popup__content.m-popup--left.m-popup--round.data-v-852cc016 {
  border-top-right-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}
.m-popup .m-popup__content.m-popup--right.data-v-852cc016 {
