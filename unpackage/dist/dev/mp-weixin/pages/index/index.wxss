page .container {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  background-color: #f4f7fb;
  margin-top: 180rpx;
}
page .card-info {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  margin: 0 24rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2f6de8 0%, #4d88f5 65%, #67a4ff 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.14);
}
page .card-info .persion-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
}
page .card-info .persion-card {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}
page .card-info .persion-card .persion-card-item {
  min-height: 120rpx;
  border-radius: 18rpx;
  padding: 20rpx 24rpx 10rpx;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
}
page .card-info .persion-card .persion-card-item-title {
  font-size: 20rpx;
  line-height: 1.4;
  color: #ffffff;
}
page .card-info .persion-card .persion-card-item-content {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}
page .card-box {
  display: flex;
  flex-direction: column;
  margin: 0 24rpx;
  background-color: #ffffff;
  border: 1rpx solid #e7edf5;
  border-radius: 24rpx;
  padding: 24rpx;
  gap: 20rpx;
}
page .card-box .card-label {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
page .card-box .card-label .view-all {
  color: #2563eb;
}
page .card-box .search-value {
  display: flex;
  flex-direction: row;
  border: 1rpx solid #dbe5f0;
  border-radius: 24rpx;
}
page .card-box .search-value .search-input {
  flex: 1;
  padding: 0 25rpx;
  height: 95rpx;
  border: none;
  background: transparent;
  color: #0f172a;
  font-size: 30rpx;
  outline: none;
}
page .card-box .search-value .scan-btn {
  border-left: 1px solid #eef2f7;
}
page .card-box .card-item {
  display: flex;
  flex-direction: column;
  border: 1px solid #e7edf5;
  border-radius: 18px;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
page .card-box .card-item .item-head {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}
page .card-box .card-item .item-head .card-item-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.25;
  word-break: break-all;
}
page .card-box .card-item .item-head .card-item-content {
  margin-top: 5px;
  font-size: 12px;
  color: #94a3b8;
  line-height: 1.45;
  word-break: break-all;
}
page .card-box .card-item .item-package {
  margin: 20rpx 0;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 20rpx;
  min-width: 0;
}
page .card-box .card-item .item-package .package-label {
  font-size: 12px;
  color: #64748b;
  line-height: 1.4;
}
page .card-box .card-item .item-package .package-value {
  flex: 1;
  font-size: 25rpx;
  font-weight: 700;
  color: #334155;
  line-height: 1.45;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
page .card-box .card-item .card-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}
page .card-box .card-item .card-metrics .metric-box {
  background: #f8fbff;
  border: 1rpx solid #e8eef7;
  border-radius: 25rpx;
  padding: 20rpx 20rpx 10rpx;
  min-width: 0;
}
page .card-box .card-item .card-metrics .metric-box .metric-label {
  font-size: 25rpx;
  color: #94a3b8;
  line-height: 1.4;
}
page .card-box .card-item .card-metrics .metric-box .metric-value {
  margin-top: 15rpx;
  font-size: 25rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.4;
  word-break: break-all;
}
page .card-box .card-item .card-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
page .card-box .card-item .card-bottom .card-cycle-text {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}
page .card-box .card-item .card-bottom .card-cycle-text .cycle-label {
  font-size: 25rpx;
  color: #64748b;
  line-height: 1.45;
}
page .card-box .card-item .card-bottom .card-cycle-text .cycle-value {
  font-size: 25rpx;
  color: #334155;
  font-weight: 800;
}