:host{display:flex;flex-direction:column}

.payment-content.data-v-0c94e3a5 {
	background-color: #fff;
	padding: 32rpx 32rpx 48rpx;
	box-sizing: border-box;
}
.payment-info.data-v-0c94e3a5 {
	margin-bottom: 32rpx;
}
.info-title.data-v-0c94e3a5 {
	font-size: 36rpx;
	font-weight: 600;
	color: #333;
	
	text-align: center;
    border-bottom: 1px solid #eef2f7;
	margin-bottom: 40rpx;
    padding-bottom: 20rpx;
}
.info-item.data-v-0c94e3a5 {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	
    padding: 10rpx 0;
}
.item-label.data-v-0c94e3a5 {
    font-size: 28rpx;
	color: #666;
}
.item-value.data-v-0c94e3a5 {
    font-size: 30rpx;
	color: #333;
	font-weight: bold;
}
.amount.data-v-0c94e3a5 {
	color: #f23030;
	font-size: 32rpx;
	font-weight: 700;
}








/* 微信小程序平台：固定方式样式 */
.method-item.fixed-method.data-v-0c94e3a5 {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding-bottom: 20rpx;
}
.method-item .method-label.data-v-0c94e3a5 {
	font-size: 24rpx;
	color: #666;
}
.method-item .method-name.data-v-0c94e3a5 {
	font-size: 24rpx;
	color: #333;
	font-weight: 500;
}

/* H5平台：可选项样式 - 添加圆角边框 */
.method-section.data-v-0c94e3a5 {
	margin-top: 8rpx;
}
.section-title.data-v-0c94e3a5 {
	font-size: 24rpx;
	color: #666;
	margin-bottom: 24rpx;
}
.method-option.data-v-0c94e3a5 {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	padding: 24rpx;
	margin-bottom: 16rpx;
	border: 2rpx solid #e5e5e5;
	border-radius: 16rpx;
	background-color: #fff;
	transition: all 0.3s ease;
}


/* 选中状态样式 */
.method-option.method-selected.data-v-0c94e3a5 {
	border-color: #2563eb;
	background-color: #f8fbff;
}
.method-left.data-v-0c94e3a5 {
	flex: 1;
	display: flex;
	flex-direction: column;
}
.method-label.data-v-0c94e3a5 {
	font-size: 24rpx;
	color: #333;
	font-weight: 500;
	margin-bottom: 8rpx;
}
.method-desc.data-v-0c94e3a5 {
	font-size: 20rpx;
	color: #999;
}
.method-right.data-v-0c94e3a5 {
	padding-left: 20rpx;
}
.radio.data-v-0c94e3a5 {
	width: 25rpx;
	height: 25rpx;
	border-radius: 50%;
	border: 2rpx solid #ddd;
	background-color: #fff;
	position: relative;
	box-sizing: border-box;
	transition: all 0.2s ease;
}
.radio-selected.data-v-0c94e3a5 {
	border-color: #2563eb;
	background-color: #2563eb;
}
.tips.data-v-0c94e3a5 {
	background-color: #f9f9f9;
	padding: 20rpx;
	border-radius: 16rpx;
	margin-bottom: 48rpx;
}
.tips-text.data-v-0c94e3a5 {
	font-size: 24rpx;
	color: #999;
	line-height: 1.4;
}
.action-buttons.data-v-0c94e3a5 {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
}
.btn.data-v-0c94e3a5 {
	flex: 1;
	text-align: center;
	border-radius: 20rpx;
	font-size: 32rpx;
	font-weight: 500;
	border: none;
	background-color: transparent;
}
.cancel-btn.data-v-0c94e3a5 {
	background-color: #ffffff;
    border: 1rpx solid #dbe5f0;
	color: #334155;
}
.confirm-btn.data-v-0c94e3a5 {
	background: linear-gradient(135deg, #2563eb 0%, #4c88f4 100%);
    color: #ffffff;
}