/* ========== 过渡与显隐工具类（ucss 兼容，不使用 @keyframes） ========== */
/*
 * 说明：
 * - 通过 transition + 切换 class 实现淡入淡出、滑入、缩放等常用效果，适用于 view / 包裹 icon 的容器等。
 * - 无限循环旋转请使用 m-loading 组件，或使用 UniElement.animate / uni.createAnimation 在脚本中实现。
 * - 用法示例：根节点 class="m-animate m-fade-from"，显示时改为 "m-animate m-fade-to"。
 */
/* ---------- 过渡基底（需与下面 from/to 成对切换） ---------- */
.m-animate {
  transition-property: opacity, transform;
  transition-duration: 300ms;
  transition-timing-function: ease-out;
}
.m-animate-fast {
  transition-duration: 150ms;
}
.m-animate-slow {
  transition-duration: 450ms;
}
.m-animate-ease-in {
  transition-timing-function: ease-in;
}
.m-animate-ease-in-out {
  transition-timing-function: ease-in-out;
}
/* ---------- 透明度 ---------- */
.m-opacity-0 {
  opacity: 0;
}
.m-opacity-1 {
  opacity: 1;
}
/* ---------- 淡入淡出（配合 .m-animate） ---------- */
.m-fade-from {
  opacity: 0;
}
.m-fade-to {
  opacity: 1;
}
/* ---------- 自下而上滑入（弹层、列表项出现） ---------- */
.m-slide-up-from {
  opacity: 0;
  transform: translateY(24rpx);
}
.m-slide-up-to {
  opacity: 1;
  transform: translateY(0);
}
/* ---------- 自下而上滑出（收起） ---------- */
.m-slide-up-out {
  opacity: 0;
  transform: translateY(-24rpx);
}
/* ---------- 自上而下滑入 ---------- */
.m-slide-down-from {
  opacity: 0;
  transform: translateY(-24rpx);
}
.m-slide-down-to {
  opacity: 1;
  transform: translateY(0);
}
/* ---------- 自左 / 自右滑入（侧栏、toast） ---------- */
.m-slide-left-from {
  opacity: 0;
  transform: translateX(24rpx);
}
.m-slide-left-to {
  opacity: 1;
  transform: translateX(0);
}
.m-slide-right-from {
  opacity: 0;
  transform: translateX(-24rpx);
}
.m-slide-right-to {
  opacity: 1;
  transform: translateX(0);
}
/* ---------- 缩放（中心放大出现） ---------- */
.m-scale-from {
  opacity: 0;
  transform: scale(0.92);
}
.m-scale-to {
  opacity: 1;
  transform: scale(1);
}
/* ---------- 显隐语义（仅状态，需自行配合 .m-animate） ---------- */
.m-visible {
  opacity: 1;
}
.m-hidden {
  opacity: 0;
}
/* 隐藏时禁止点击（部分端若不支持 pointer-events，仍可依赖透明度与业务层 v-if） */
.m-hidden-touch {
  opacity: 0;
  pointer-events: none;
}
/* ---------- 图标常用：单次旋转过渡（如展开箭头），非无限旋转 ---------- */
.m-rotate-0 {
  transform: rotate(0deg);
}
.m-rotate-90 {
  transform: rotate(90deg);
}
.m-rotate-180 {
  transform: rotate(180deg);
}
.m-rotate-270 {
  transform: rotate(270deg);
}
