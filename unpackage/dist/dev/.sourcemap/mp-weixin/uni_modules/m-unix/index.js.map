<template>
	<view class="m-rate" @tap.stop="">
		<view
			v-for="i in quantity"
			:key="i"
			class="m-rate__star-wrap"
			@tap="onStarTap(i)"
		>
			<text
				class="m-rate__star"
				:style="{ 'font-size': size + 'px', color: starColor(i) }"
			>{{ hollow && i > effectiveCurrent ? '☆' : '★' }}</text>
		</view>
	</view>
</template>

<script lang="uts">
export default {
	name: 'mRate',
	emits: ['change', 'update:current'],
	props: {
		quantity: {
			type: Number,
			default: 5
		},
		current: {
			type: Number,
			default: 0
		},
		score: {
			type: [Number, String],
			default: 1
		},
		disabled: {
			type: Boolean,
			default: false
		},
		size: {
			type: Number,
			default: 20
		},
		normal: {
			type: String,
			default: '#b2b2b2'
		},
		active: {
			type: String,
			default: '#EB0909'
		},
		hollow: {
			type: Boolean,
			default: false
		},
		params: {
			type: [Number, String],
			default: 0
		}
	},
	computed: {
		effectiveCurrent(): number {
			const c = this.current as number
			const q = this.quantity as number
			if (c < 0) {
				return 0
			}
			if (c > q) {
				return q
			}
			return c
		},
	},
	methods: {
		starColor(i: number): string {
			if (i <= this.effectiveCurrent) {
				return this.active as string
			}
			return this.normal as string
		},
		onStarTap(i: number) {
			if (this.disabled) {
				return
			}
			const p = this.params
			const np = typeof p === 'number' ? p as number : parseInt('' + p)
			this.$emit('update:current', i)
			this.$emit('change', { index: i, params: isNaN(np) ? 0 : np })
		}
	}
}
</script>

<style lang="scss">
.m-rate {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.m-rate__star-wrap {
	position: relative;
	margin-right: 8rpx;
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: center;
}

.m-rate__star {
	line-height: 1;
}
</style>
