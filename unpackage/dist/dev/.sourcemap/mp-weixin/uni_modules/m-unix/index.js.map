<template>
	<view class="m-popup">
		<m-overlay
			:show="overlayVisible"
			:opacity="overlayOpacity"
			:z-index="zIndex - 1"
			:duration-ms="duration"
			@click="handleOverlayClick"
		></m-overlay>
		<view
			v-if="contentMounted"
			class="m-popup__content"
			:class="[
				`m-popup--${position}`,
				{ 'm-popup--round': round },
				{ 'm-popup__content--show': panelShowClass }
			]"
			:style="contentStyle"
		>
			<view class="m-popup__content-inner" :class="{ 'm-popup--closeable': closeable }">
				<slot></slot>
				<view class="m-popup__close" @tap="handleCloseClick" v-if="closeable">
					<icon name="close" size="40" color="#c0c4cc"></icon>
				</view>
			</view>
		</view>
	</view>
</template>

<script lang="uts">
export default {
	name: 'mPopup',
	emits: ['close', 'overlay-click', 'update:show', 'update:visible'],
	props: {
		show: {
			type: Boolean,
			default: false
		},
		visible: {
			type: Boolean,
			default: false
		},
		position: {
			type: String,
			default: 'bottom'
		},
		round: {
			type: Boolean,
			default: true
		},
		overlayOpacity: {
			type: [Number, String],
			default: 0.5
		},
		closeable: {
			type: Boolean,
			default: false
		},
		zIndex: {
			type: [Number, String],
			default: 999
		},
		closeOnClickOverlay: {
			type: Boolean,
			default: true
		},
		maxHeight: {
			type: [Number, String],
			default: 80
		},
		/** 是否启用显示/隐藏过渡 */
		animation: {
			type: Boolean,
			default: true
		},
		/** 与 CSS 过渡时长一致（毫秒），关闭后延迟卸载面板 */
		duration: {
			type: Number,
			default: 300
		}
	},
	data() {
		return {
			leaving: false as boolean,
			panelActive: false as boolean,
			closeTimer: null as number | null
		}
	},
	computed: {
		isOpen(): boolean {
			return this.show || this.visible
		},
		contentMounted(): boolean {
			if (!this.animation) {
				return this.isOpen
			}
			return this.isOpen || this.leaving
		},
		overlayVisible(): boolean {
			return this.isOpen
		},
		panelShowClass(): boolean {
			if (!this.animation) {
				return this.isOpen
			}
			return this.panelActive
		},
		contentStyle(): any {
			const sec = this.duration / 1000
			const durStr = sec + 's'
			const pos = this.position as string
			const style: any = {
				zIndex: this.zIndex,
				transitionDuration: durStr
			}
			// 左右侧：高度由样式 top:0 + bottom:0 拉满视口，不再套默认 maxHeight（避免 80vh 裁成「不满屏」）
			if (pos === 'left' || pos === 'right' || pos === 'fullscreen') {
				style.maxHeight = '100%'
			} else {
				style.maxHeight = this.maxHeight + 'vh'
			}
			return style
		}
	},
	watch: {
		isOpen: {
			handler(val: boolean) {
				this.onIsOpenChange(val)
			}
		}
	},
	mounted() {
		if (this.isOpen) {
			this.openEnter()
		}
	},
	beforeUnmount() {
		this.cancelCloseTimer()
	},
	methods: {
		cancelCloseTimer() {
			if (this.closeTimer != null) {
				clearTimeout(this.closeTimer)
				this.closeTimer = null
			}
		},
		openEnter() {
			if (!this.animation) {
				this.panelActive = true
				this.leaving = false
				return
			}
			this.leaving = false
			this.panelActive = false
			this.$nextTick(() => {
				this.panelActive = true
			})
		},
		closeLeave() {
			if (!this.animation) {
				this.panelActive = false
				this.leaving = false
				return
			}
			this.panelActive = false
			this.leaving = true
			this.cancelCloseTimer()
			const ms = this.duration
			this.closeTimer = setTimeout(() => {
				this.leaving = false
				this.closeTimer = null
			}, ms) as number
		},
		onIsOpenChange(val: boolean) {
			if (val) {
				this.cancelCloseTimer()
				this.openEnter()
			} else {
				this.closeLeave()
			}
		},
		emitDismiss() {
			this.$emit('update:show', false)
			this.$emit('update:visible', false)
			this.$emit('close')
		},
		handleOverlayClick() {
			if (this.closeOnClickOverlay) {
				this.emitDismiss()
			}
			this.$emit('overlay-click')
		},
		handleCloseClick() {
			this.emitDismiss()
		}
	}
}
</script>

<style scoped lang="scss">
.m-popup {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	pointer-events: none;

	.m-popup__content {
		position: absolute;
		background-color: #ffffff;
		box-sizing: border-box;
		pointer-events: auto;
		overflow-y: auto;
		transition-property: transform, opacity;
		transition-timing-function: cubic-bezier(0.25, 0.8, 0.25, 1);

		&.m-popup--bottom {
			bottom: var(--uni-safe-area-inset-bottom, 0px);
			left: 0;
			width: 100%;
			transform: translateY(100%);

			&.m-popup__content--show {
				transform: translateY(0);
			}

			&.m-popup--round {
				border-top-left-radius: 20rpx;
				border-top-right-radius: 20rpx;
			}
		}

		&.m-popup--center {
			top: 50%;
			left: 50%;
			width: auto;
			min-width: 520rpx;
			max-width: 86%;
			opacity: 0;
			transform: translate(-50%, -46%) scale(0.94);
			box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.12);
			overflow-x: hidden;

			&.m-popup__content--show {
				opacity: 1;
				transform: translate(-50%, -50%) scale(1);
			}

			&.m-popup--round {
				border-radius: 20rpx;
			}

			/* 居中弹层：内边距与底部/侧边区分，避免插槽内容贴边 */
			.m-popup__content-inner {
				padding: 44rpx 48rpx 40rpx;
			}

			&.m-popup--closeable .m-popup__content-inner {
				padding-top: 56rpx;
			}
		}

		&.m-popup--top {
			top: var(--uni-safe-area-inset-top, 0px);
			left: 0;
			width: 100%;
			transform: translateY(-100%);

			&.m-popup__content--show {
				transform: translateY(0);
			}

			&.m-popup--round {
				border-bottom-left-radius: 20rpx;
				border-bottom-right-radius: 20rpx;
			}
		}

		&.m-popup--left {
			top: var(--uni-safe-area-inset-top, 0px);
			left: 0;
			bottom: var(--uni-safe-area-inset-bottom, 0px);
			width: 70%;
			max-width: 600rpx;
			transform: translateX(-100%);

			&.m-popup__content--show {
				transform: translateX(0);
			}

			&.m-popup--round {
				border-top-right-radius: 20rpx;
				border-bottom-right-radius: 20rpx;
			}
		}

		&.m-popup--right {
			top: var(--uni-safe-area-inset-top, 0px);
			right: 0;
			bottom: var(--uni-safe-area-inset-bottom, 0px);
			width: 70%;
			max-width: 600rpx;
			transform: translateX(100%);

			&.m-popup__content--show {
				transform: translateX(0);
			}

			&.m-popup--round {
				border-top-left-radius: 20rpx;
				border-bottom-left-radius: 20rpx;
			}
		}

		/* 全屏层：弹屏广告、大图引导等；插槽区无默认内边距，由业务铺满 */
		&.m-popup--fullscreen {
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			width: 100%;
			height: 100%;
			max-height: 100%;
			background-color: transparent;
			opacity: 0;
			transform: scale(0.96);
			border-radius: 0;
			overflow: hidden;

			&.m-popup__content--show {
				opacity: 1;
				transform: scale(1);
			}

			.m-popup__content-inner {
				padding: 0;
				width: 100%;
				height: 100%;
				box-sizing: border-box;
			}

			&.m-popup--closeable .m-popup__content-inner {
				padding-top: 0;
			}
		}
	}

	.m-popup__content-inner {
		position: relative;
		padding: 30rpx;
		box-sizing: border-box;

		.m-popup__close {
			position: absolute;
			top: 10rpx;
			right: 10rpx;
			padding: 10rpx;
		}
	}
}
</style>
