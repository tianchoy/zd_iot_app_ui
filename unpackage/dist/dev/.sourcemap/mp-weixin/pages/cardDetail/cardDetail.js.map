	const current = ref(0)
	const handleClick = (e: UTSJSONObject) => {
		current.value = e.getNumber('index') ?? 0
	}

	const changeTab = (e: CardDetailTabEvent) => {
		active.value = e.index
		activeName.value = e.item.name
	}

	const showMore = () => {
		uni.__f__('log','at pages/cardDetail/cardDetail.uvue:296',pkgMore.value)
		pkgMore.value = !pkgMore.value
	}

		const goBack = () => {
			uni.navigateBack({
				delta: 1
			})
		}

	onLoad((options) => {
		const cardNumber = options.getString('card_number') ?? ''
		uni.__f__('log','at pages/cardDetail/cardDetail.uvue:308',cardNumber)
		card_number.value = cardNumber
	})
</script>

