<template>
	<topNavBar title="我的" :show-back="false" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		
		<view class="card-info mb-24">
			<view class="persion-card">
				<view class="persion-card-item"  @click="cardType(0)">
					<text class="persion-card-item-title">我的卡片</text>
					<text class="persion-card-item-content"> {{ cardListSum.all != null ? cardListSum.all : 0 }}</text>
				</view>
				<view class="persion-card-item"  @click="cardType(1)">
					<text class="persion-card-item-title">在用卡片</text>
					<text class="persion-card-item-content"> {{ cardListSum.inUse != null ? cardListSum.inUse : 0 }}</text>
				</view>
				<view class="persion-card-item"  @click="cardType(2)">
					<text class="persion-card-item-title">异常卡片</text>
					<text class="persion-card-item-content"> {{ cardListSum.inNotUse != null ? cardListSum.inNotUse : 0 }}</text>
				</view>
			</view>
		</view>
		<view class="card-box">
			<view class="item"  @click="toOrder">
				<text class="order-label">我的订单</text>
				<rice-icon name="arrow-right" size="20rpx"></rice-icon>
			</view>
			<view class="item">
				<text class="order-label">绑定卡片</text>
				<rice-icon name="arrow-right" size="20rpx"></rice-icon>
			</view>
			<view class="item">
				<text class="order-label">常见问题</text>
				<rice-icon name="arrow-right" size="20rpx"></rice-icon>
			</view>
		</view>
		<view class="btn-box">
			<rice-button v-if="!isLogin()" type="primary" width="100%" shape="round" @click="handleLogin">登录</rice-button>
			<rice-button v-else type="error" width="100%" shape="round"  @click="handleLogout">退出登录</rice-button>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { login,getTenantInfo,queryCardListSum} from '@/api/http.uts'
	import type { CardListSumData } from '@/api/types.uts'
	import { setStorageSync,getTenantId,getToken ,clearToken} from '@/common/config.uts'


	const title = ref('用户');
	const wxGetPhoneLogin = ref<string>('')

	// 卡片类型切换
	const cardType = (type: number) => {
		if (!isLogin()) return 
		uni.reLaunch({
			url: '/pages/card/card?type=' + type
		})
	}
	// 跳转订单记录
	const toOrder = () => {
		if (!isLogin()) return 
		uni.navigateTo({
			url: '/pages/myOrder/myOrder'
		})
	}

	//登录
	const userId = ref<string>('')
	const userLoginByOpenid = async (codes: string) => {
		const res = await login({
			xcxCode: codes,
			isLogin: '1',
		})
		
		if(res.code == 200){
			userId.value = '' + res.data.id
			uni.navigateTo({
				url: '/pages/login/login?wxGetPhoneLogin=' + wxGetPhoneLogin.value + '&userId=' + userId.value
			})
		}
	}

	//获取 code
	const code = ref<string>('')
	const getCode = () => {
		uni.login({
			success: (res) => {
				code.value = res.code
				userLoginByOpenid(res.code);
			}
		})
	}

		// 获取租户页面配置
	const getTenantInfos = async () => {
		const res = await getTenantInfo(getTenantId(),false)
		if(res.code == 200){
			const tenantInfo = res.data
			wxGetPhoneLogin.value = '' + tenantInfo.wxGetPhoneLogin
			// setStorageSync('tenant_infos', tenantInfo)
		}
	}

	const handleLogin = () => {
		const token = getToken()
		if(!token){
			getTenantInfos().then(() => {
				getCode()
			})
		}
	}

	// 退出登录
	const handleLogout = () => {
		clearToken()
		uni.showToast({
			title: '退出登录成功',
			icon: 'none'
		})
		uni.reLaunch({
			url: '/pages/index/index'
		})
	}

	// 查询卡列表统计
	const cardListSum = ref<CardListSumData>({ all: 0, inUse: 0, inNotUse: 0 })
	const getCardListSum = async () => {
		try {
			const res = await queryCardListSum()
			if (res.code === 200) {
				cardListSum.value = res.data
				uni.__f__('log','at pages/mine/mine.uvue:131','查询卡列表统计成功:', res.data)
			} else {
				uni.__f__('log','at pages/mine/mine.uvue:133','查询卡列表统计失败:', res.msg)
			}
		} catch (error) {
			uni.__f__('error','at pages/mine/mine.uvue:136','查询卡列表统计异常:', error)
		}
	}

	// 检查token状态
	const checkToken = (): boolean => {
		const token = getToken()
		return !!token
	}

	// 检查是否登录
	const isLogin = (): boolean => {
		if (!checkToken()) {
			uni.showToast({
				title: '请先登录',
				icon: 'none'
			})
			return false
		}
		return true
	}


	onLoad(() => {
		// 检查token状态
		if (checkToken()) {
			//加载统计数据
			getCardListSum()
		}
	})
</script>

