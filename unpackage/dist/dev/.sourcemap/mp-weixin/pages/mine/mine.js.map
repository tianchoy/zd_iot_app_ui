	display: flex;
	flex-direction: column;
	background-color: #f4f7fb;
	height: 100%;
	.card-info{
		display: flex;
		flex-direction: column;
		padding: 24rpx;
		margin: 0 24rpx;
		border: none;
		border-radius: 24rpx;
		background: linear-gradient(135deg, #2f6de8 0%, #4d88f5 65%, #67a4ff 100%);
		color: #ffffff;
		box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.14);
		.persion-name{
			font-size: 30rpx;
			font-weight: bold;
			color: #ffffff;
		}
		.persion-card{
			display: flex;
			flex-direction: row;

			.persion-card-item{
				flex:1;
				margin: 0 10rpx;
				min-height: 120rpx;
				border-radius: 18rpx;
				padding: 20rpx 24rpx;
				background: rgba(255, 255, 255, 0.12);
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
			}
			.persion-card-item-title{
				font-size: 22rpx;
				line-height: 1.4;
				color: #ffffff;
			}
			.persion-card-item-content{
				margin-top: 20rpx;
				font-size: 40rpx;
				font-weight: 800;
				line-height: 1;
			}
		}
	}
	.card-box{
		display: flex;
		flex-direction: column;
		border-radius: 24rpx;
		margin: 0 24rpx;
		background-color: #ffffff;
		.item{
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			padding: 24rpx;
			border-bottom: 1px solid #e7edf5;
			.order-label{
				font-weight: bold;
			}
		}

	}
	.btn-box{
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		margin: 30rpx 24rpx 0 24rpx;
	}
	
}
</style>
