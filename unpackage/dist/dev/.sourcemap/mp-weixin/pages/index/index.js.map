<script setup lang="uts">
	import { ref, onMounted, onUnmounted } from 'vue'
	import { login } from '@/api/http.uts'
	
	const title = ref('Hello')
	const show = ref(false)
	const card_number = ref('')

	const goRecharge = () => {
		uni.__f__('log','at pages/index/index.uvue:87','去充值')
		uni.navigateTo({
			url: '/pages/recharge/recharge'
		})
	}
	
	const scanCode = () => {
		uni.navigateTo({
			url: '/pages/scanCode/scanCode'
		})
	}
	
	const handleQuery = () => {
		if (!card_number.value) {
			uni.showToast({
				title: '请输入卡号',
				icon: 'none'
			})
			return
		}
		uni.__f__('log','at pages/index/index.uvue:107','查询卡号:', card_number.value)
		// 处理查询逻辑
	}
	
	// 接收扫码结果
	const onScanResult = (data: any) => {
		uni.__f__('log','at pages/index/index.uvue:113','收到扫码结果:', data)
		if (data && data.result) {
			// 直接将结果赋值给 card_number
			card_number.value = data.result
			uni.showToast({
				title: '扫码成功',
				icon: 'success'
			})
			// 自动查询
			// handleQuery()
		}
	}

	// 卡片类型切换
	const cardType = (type: number) => {
		uni.__f__('log','at pages/index/index.uvue:128',type)
		uni.reLaunch({
			url: '/pages/card/card?type=' + type
		})
	}
	
	onMounted(() => {
		// 监听扫码结果事件
		uni.$on('scanResult', onScanResult)
		// getLogin()
	})

	const getLogin = async () => {
		const res = await login({
			phone: '13800000000',
			password: '123456'
		})
	}
	
	onUnmounted(() => {
		// 移除事件监听
		uni.$off('scanResult', onScanResult)
	})
</script>

