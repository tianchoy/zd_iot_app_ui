<template>
	<topNavBar title="卡片" :show-back="false" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		
		<view class="card-box mb-24">
			<view class="card-label">卡号查询</view>
			<view class="search-value mt-24">
				<rice-input
					v-model="card_number"
					placeholder="请输入 ICCID / MSISDN"
					class="search-input"
					@input="handleInput"
				>
				</rice-input>
				<rice-button class="scan-btn" height="100%" @click="scanCode">
					<rice-icon name="scan" size="40rpx"></rice-icon>
				</rice-button>
				<rice-button type="primary" color="#1989fa" textColor="#ffffff" height="100%" @click="handleQuery">查询</rice-button>
			</view>
			
		</view>
		
		<view class="card-box">
			<view class="card-tabs">
				<rice-tabs
				  v-model="current"
				  line-color="#ffffff" 
				  :list="tabs" 
				  :line-width="0" 
				  :title-active-color="'#2563eb'" 
				  @click="handleClick" 
				  :customStyle="{height:'85rpx',padding:'10rpx',border:'1rpx solid #e5edf6'}"
				>
				</rice-tabs>
			</view>
			<scroll-view 
				class="card-list" 
				scroll-y="true"
				:style="{ height: scrollViewHeight + 'px' }"
			>
				<view class="card-item" v-for="(card, index) in filteredCardList" :key="index" @click="handleDetail(card)">
					<view class="item-head">
						<view class="item-head-label">
							<text class="card-item-title">{{ getCardText(card, 'cardNumber') }}</text>
							<text class="card-item-content">ICCID: {{ getCardText(card, 'iccid') }}</text>
						</view>
						<text class="status-tag" :class="getStatusClass(getCardText(card, 'status'))">{{ getCardText(card, 'status') }}</text>
					</view>
					<view class="item-package">
						<text class="package-label">当前套餐:</text>
						<text class="package-value">{{ getCardText(card, 'currentPackage') }}</text>
					</view>
					<rice-divider dashed :customStyle="{margin:'0'}"></rice-divider>
					<view class="card-metrics">
						<view class="metric-box mr-24">
							<view class="metric-label">到期时间</view>
							<view class="metric-value">{{ getCardText(card, 'expireDate') }}</view>
						</view>
						<view class="metric-box">
							<view class="metric-label">本月流量</view>
							<view class="metric-value">{{ getCardText(card, 'usedTraffic') }} / {{ getCardText(card, 'totalTraffic') }}</view>
						</view>
					</view>
					<view class="card-bottom">
						<view class="card-cycle-text">
							<text class="cycle-label">当前周期：</text>
							<text class="cycle-value">{{ getCardText(card, 'currentCycle') }}</text>
						</view>
						<rice-button type="primary" size="small" >去充值</rice-button>
					</view>
				</view>
			</scroll-view>
		</view>

		<!-- 空状态 -->
		<view v-if="filteredCardList.length === 0" class="empty-state">
			<text class="empty-text">暂无卡片数据</text>
		</view>
		<customService></customService>
	</view>
</template>

<script setup lang="uts">
import { ref, computed, onMounted, nextTick } from 'vue'
import { queryCardList,login,getTenantInfo } from '@/api/http.uts'
import { getPageParams } from '@/utils/routerParams'
import { getToken,getTenantId,isWechat,isH5 } from '@/common/config.uts'
import { CardItem } from '@/api/types.uts'

const card_number = ref('gn20260603164757')
const queryKeyword = ref('')
const tabStatuses = ['全部', '在用', '异常']
const current = ref(0)
const scrollViewHeight = ref(0)
const loading = ref<boolean>(false)

// 完整的卡片列表数据
const allCardList = ref<CardItem[]>([
	{
		id: 1,
		cardNumber: '1064916585160',
		iccid: '89860421123456789012',
		tag: '主卡',
		status: '在用',
		currentPackage: '车联网月包20G',
		expireDate: '2026-04-30',
		usedTraffic: '11.34GB',
		totalTraffic: '20GB',
		currentCycle: '第1期 / 共12期'
	},
	{
		id: 2,
		cardNumber: '1064916585161',
		iccid: '89860421123456789013',
		tag: '副卡',
		status: '在用',
		currentPackage: '车联网月包10G',
		expireDate: '2026-05-15',
		usedTraffic: '5.21GB',
		totalTraffic: '10GB',
		currentCycle: '第2期 / 共6期'
	},
	{
		id: 3,
		cardNumber: '1064916585162',
		iccid: '89860421123456789014',
		tag: '测试卡',
		status: '异常',
		currentPackage: '测试套餐1G',
		expireDate: '2026-03-31',
		usedTraffic: '1GB',
		totalTraffic: '1GB',
		currentCycle: '第1期 / 共1期'
	}
])

type TabItem = {
	name: string
}

// 计算每个 tab 对应的卡片数量
const tabNumbers = computed<number[]>(() => {
	const total = allCardList.value.length
	const inUse = allCardList.value.filter((card: CardItem) => card.status === '在用').length
	const abnormal = allCardList.value.filter((card: CardItem) => card.status !== '在用').length
	return [total, inUse, abnormal]
})

const tabs = computed<TabItem[]>(() => {
	const numbers = tabNumbers.value
	return [
		{name: `全部 ${numbers[0]}`},
		{name: `在用 ${numbers[1]}`},
		{name: `异常 ${numbers[2]}`}
	]
})

const handleDetail = (card: CardItem) => {
	uni.__f__('log','at pages/card/card.uvue:159',card)
	uni.navigateTo({
		url: '/pages/cardDetail/cardDetail?cardNumber=' + card.cardNumber
	})
}

// 根据选中的 tab 和查询卡号过滤卡片列表
const filteredCardList = computed<CardItem[]>(() : CardItem[] => {
	const currentStatus = tabStatuses[current.value]
	let list = allCardList.value
	if (currentStatus !== '全部') {
		list = list.filter((card: CardItem) : boolean => {
			const status = '' + card.status
			if (currentStatus === '异常') {
				return status !== '在用'
			}
			return status === currentStatus
		})
	}
	if (queryKeyword.value !== '') {
		list = list.filter((card: CardItem) : boolean => {
			const cardNumber = '' + card.cardNumber
			return cardNumber.indexOf(queryKeyword.value) !== -1
		})
	}
	return list
})

const getCardText = (card: CardItem, key: string): string => {
	const value = card[key]
	return value == null ? '' : '' + value
}

// 获取状态样式类
const getStatusClass = (status: string): string => {
	switch (status) {
		case '在用':
			return 'status-completed'
		case '异常':
			return 'status-pending'
		case '停机':
			return 'status-refunded'
		default:
			return ''
	}
}

const handleClick = (e: UTSJSONObject) => {
	if(e.index != null){
		current.value = e.index as number
	}
}

const scanCode = () => {
	uni.navigateTo({
		url: '/pages/scanCode/scanCode'
	})
}


const handleInput = () => {
	if (card_number.value.trim() === '') {
		queryKeyword.value = ''
	}
}

const handleQuery = () => {
	const keyword = card_number.value.trim()
	if (!keyword) {
		uni.showToast({
			title: '请输入卡号',
			icon: 'none'
		})
		return
	}
	queryKeyword.value = keyword
	uni.navigateTo({
		url: '/pages/cardDetail/cardDetail?cardNumber=' + keyword
	})
}

// 接收扫码结果
const onScanResult = async (data: UTSJSONObject) => {
	const result = data.getString('result') ?? ''
	uni.__f__('log','at pages/card/card.uvue:243',result)
	if (result.length > 0) {
		card_number.value = result
		uni.showToast({
			title: '扫码成功',
			icon: 'success'
		})
		// 自动查询
		await handleQuery()
	}
}

// 计算 scroll-view 的高度
const calculateScrollHeight = () => {




















}

// 查询卡列表
const getCardList = async () => {
	loading.value = true
	try {
		const res = await queryCardList({
			status: '0'
		})
		if (res.code === 200) {
			uni.__f__('log','at pages/card/card.uvue:287','查询卡列表成功:', res.data)
			allCardList.value = res.data.list as CardItem[]
		} else {
			uni.__f__('log','at pages/card/card.uvue:290','查询卡列表失败:', res.msg)
			allCardList.value = []
			uni.showToast({
				title: res.msg || '查询失败',
				icon: 'none'
			})
		}
	} catch (error) {
		uni.__f__('error','at pages/card/card.uvue:298','查询卡列表异常:', error)
		allCardList.value = []
		uni.showToast({
			title: '网络异常，请稍后重试',
			icon: 'none'
		})
	} finally {
		loading.value = false
	}
}

// 检查token状态
const checkToken = (): boolean => {
	const token = getToken()
	return !!token
}

// 检查是否登录
const isLogin = (): boolean => {
	if (!checkToken()) {
		uni.showToast({
			title: '请先登录',
			icon: 'none'
		})
		return false
	}
	return true
}

//登录
const userId = ref<string>('')
const wxGetPhoneLogin = ref<string>('')
const userLoginByOpenid = async (codes: string) => {
	const res = await login({
		xcxCode: codes,
		isLogin: '1',
	})
	
	if(res.code == 200){
		userId.value = '' + res.data.id
		uni.navigateTo({
			url: '/pages/login/login?wxGetPhoneLogin=' + wxGetPhoneLogin.value + '&userId=' + userId.value
		})
	}
}

//获取 code
const code = ref<string>('')
const getCode = () => {
	uni.login({
		success: (res) => {
			code.value = res.code
			userLoginByOpenid(res.code);
		}
	})
}

	// 获取租户页面配置
const getTenantInfos = async () => {
	const res = await getTenantInfo(getTenantId(),false)
	if(res.code == 200){
		const tenantInfo = res.data
		wxGetPhoneLogin.value = '' + tenantInfo.wxGetPhoneLogin
	}
}

//根据平台不一致，请求的方式不一致
const platform = () => {
	if(isWechat()){
		// 检查token状态
		if (checkToken()) {
			//加载列表数据
			getCardList()
		}else{
			// 获取租户页面配置
			getTenantInfos().then(() => {
				getCode()
			})
		}
	}else if(isH5()){
		getCardList()
	}
}

onLoad((options) => {
	platform()
	uni.$on('scanResult', onScanResult)
})

onMounted(() => {
	calculateScrollHeight()
})

onUnload(() => {
		// 移除事件监听
		uni.$off('scanResult', onScanResult)
	})
</script>

