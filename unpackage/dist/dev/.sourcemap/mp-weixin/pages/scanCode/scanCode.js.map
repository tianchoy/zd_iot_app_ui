<template>
  <view class="scan-page">












    

    <view class="other-scan-container">
      <view class="scan-tip">
        <text class="tip-icon">📷</text>
        <text class="tip-text">正在启动相机...</text>
      </view>
    </view>

  </view>
</template>

<script setup lang="uts">
import { onMounted, onUnmounted } from 'vue'







// 返回上一页并传递结果
const goBackWithResult = (result: string) => {
  uni.__f__('log','at pages/scanCode/scanCode.uvue:38','扫码结果:', result)
  uni.$emit('scanResult', { result: result })
  uni.navigateBack({ delta: 1 })
}

const stopScanH5 = async () => {
  if (!html5QrCode) return
  try {
    const state = html5QrCode.getState()
    if (state === 2 || state === 3) {
      await html5QrCode.stop()
    }
  } catch (err) {
    uni.__f__('log','at pages/scanCode/scanCode.uvue:51','停止扫描失败:', err)
  } finally {
    html5QrCode = null
  }
}

const handleBack = () => {



  uni.navigateBack({ delta: 1 })
}

// ==================== 微信小程序 ====================

onMounted(() => {
  // 延迟一下，确保页面完全加载
  setTimeout(() => {
    uni.scanCode({
      onlyFromCamera: true,
      scanType: ['qrCode', 'barCode'],
      success: (res) => {
        uni.__f__('log','at pages/scanCode/scanCode.uvue:73','小程序扫码成功:', res.result)
        goBackWithResult(res.result as string)
      },
      fail: (err) => {
        uni.__f__('log','at pages/scanCode/scanCode.uvue:77','小程序扫码失败或取消:', err)
        uni.showToast({
          title: '扫码失败或已取消',
          icon: 'none',
          duration: 1500,
          complete: () => {
            setTimeout(() => {
              uni.navigateBack({ delta: 1 })
            }, 500)
          }
        })
      }
    })
  }, 100)
})


// ==================== App ====================




























// ==================== H5 ====================



































































































































































</script>

