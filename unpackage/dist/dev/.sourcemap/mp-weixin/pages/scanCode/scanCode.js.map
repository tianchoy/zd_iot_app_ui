<template>
  <view class="scan-page">









  </view>
</template>

<script setup lang="uts">
  import { onMounted, onUnmounted } from 'vue'
  





  
  // 返回上一页并传递结果
  const goBackWithResult = (result: string) => {
    uni.__f__('log','at pages/scanCode/scanCode.uvue:26','扫码结果:', result)
    uni.$emit('scanResult', { result: result })
    uni.navigateBack({ delta: 1 })
  }
  
  const handleBack = () => {





    uni.navigateBack({ delta: 1 })
  }
  
  // ==================== 微信小程序 ====================

  onMounted(() => {
    uni.scanCode({
      onlyFromCamera: true,
      scanType: ['qrCode', 'barCode'],
      success: (res) => {
        uni.__f__('log','at pages/scanCode/scanCode.uvue:47','小程序扫码成功:', res.result)
        goBackWithResult(res.result as string)
      },
      fail: (err) => {
        uni.__f__('log','at pages/scanCode/scanCode.uvue:51','小程序扫码失败或取消:', err)
        uni.navigateBack({ delta: 1 })
      }
    })
  })

  
  // ==================== App ====================















  
  // ==================== H5 ====================

















































































</script>

<style lang="scss" scoped>
  .scan-page {
    position: relative;
    width: 100%;
    height: 100vh;
    background-color: #000000;
  }
  









































