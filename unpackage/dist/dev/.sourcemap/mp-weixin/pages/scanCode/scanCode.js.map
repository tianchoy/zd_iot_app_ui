<template>
	<topNavBar
	  title="扫一扫" 
	  :show-back="true" 
	  backgroundColor="#000000" 
	  textColor="#ffffff" 
	  :showCapsule="false"
	  @back="handleBack"
	></topNavBar>
  <view class="scan-page">
    <view class="scan-area">

      <!-- 小程序和 App 使用原生扫码，不需要 UI -->
      <view class="native-scan-tip">
        <text class="tip-text">正在启动相机...</text>
      </view>

      









    </view>
  </view>
</template>

<script setup lang="uts">
  import { onMounted, onUnmounted, nextTick } from 'vue'
  




  
  // 返回上一页并传递结果
  const goBackWithResult = (result: string) => {
    uni.$emit('scanResult', { result: result })
    uni.navigateBack({ delta: 1 })
  }
  
  const handleBack = () => {





    uni.navigateBack({ delta: 1 })
  }
  
  // ==================== 微信小程序 ====================

  const startScanWx = () => {
    uni.scanCode({
      onlyFromCamera: true,
      scanType: ['qrCode', 'barCode'],
      success: (res) => {
        goBackWithResult(res.result as string)
      },
      fail: (err) => {
        // 用户取消或失败都返回上一页
        setTimeout(() => {
          uni.navigateBack({ delta: 1 })
        }, 300)
      }
    })
  }
  
  onMounted(() => {
    // 确保页面完全加载后再调用
    nextTick(() => {
      startScanWx()
    })
  })

  
  // ==================== App ====================






















  
  // ==================== H5（使用本地安装的库，更稳定） ====================





















































































</script>

<style lang="scss" scoped>
  .scan-page {
    position: relative;
    width: 100%;
    height: 100vh;
    background-color: #000000;
  }
  
  .scan-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: calc(100vh - 88rpx);
  }
  
  .tip-text {
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
  }
  
  .native-scan-tip {
    .tip-text {
      font-size: 32rpx;
    }
  }
  

































