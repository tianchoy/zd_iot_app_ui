							.detail-label {
								width: 100rpx;
								font-size: 26rpx;
								color: #9ca3af;
								flex-shrink: 0;
							}
							
							.detail-value {
								flex: 1;
								font-size: 26rpx;
								color: #374151;
							}
						}
						.last{
							margin-bottom: 0;
						}
					}
					
					.order-footer {
						display: flex;
						flex-direction: row;
						justify-content: space-between;
						align-items: center;
						padding-top: 20rpx;
						
						.price {
							font-size: 28rpx;
							font-weight: bold;
							color: #ef4444;
							margin-right: 20rpx;
						}
						
						.pay-btn {
							background: #eff6ff;
							border: 1px solid #bfdbfe;
							color: #2563eb;
							font-size: 24rpx;
							padding: 10rpx 25rpx;
							border-radius: 40rpx;
							font-weight: bold;
						}
					}
				}
			}
		}
	}
</style>