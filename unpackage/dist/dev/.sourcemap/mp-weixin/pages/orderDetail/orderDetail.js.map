	.package-card {
		background-color: #ffffff;
		border-radius: 24rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
		
		.package-header {
			display: flex;
			flex-direction: row; 
			justify-content: space-between;
			align-items: center;
			margin-bottom: 16rpx;
			
			.package-name {
				font-size: 36rpx;
				font-weight: 600;
				color: #1f2937;
			}
			
			.status-tag {
				font-size: 24rpx;
