<template>
	<view>
		<topNavBar title="订单详情" @back="handleBack" :show-back="true" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
		<scroll-view class="container" scroll-y :enhanced="true">
			<!-- 套餐名称卡片 -->
			<view class="package-card">
				<view class="package-header">
					<text class="package-name">{{ orderDetail.pkgName || '-' }}</text>
					<text class="status-tag" :class="getStatusClass(getOrderStatusText())">{{ getOrderStatusText() }}</text>
				</view>
				<view class="card-number-row">
					<text class="card-number-label">当前卡号：</text>
					<text class="card-number">{{ orderDetail.rechargeNo || '-' }}</text>
				</view>
			</view>
			
			<!-- 订单信息卡片 -->
			<view class="info-card">
				<view class="info-row">
					<text class="info-label">订单编号</text>
					<text class="info-value">{{ orderDetail.orderNo || '-' }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">ICCID</text>
					<text class="info-value">{{ orderDetail.iccid || '-' }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">支付金额</text>
					<text class="info-value price">¥{{ orderDetail.payAmount || orderDetail.orderAmount || 0 }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">订单状态</text>
					<text class="info-value status">{{ getOrderStatusText() }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">支付方式</text>
					<text class="info-value">{{ getPaymentMethod() }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">下单时间</text>
					<text class="info-value">{{ formatDateTime(orderDetail.orderCreateTime) }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">支付时间</text>
					<text class="info-value">{{ formatDateTime(orderDetail.payTime) || '--' }}</text>
				</view>
				<view v-if="orderDetail.payFailReason" class="info-row">
					<text class="info-label">支付失败原因</text>
					<text class="info-value status-fail">{{ orderDetail.payFailReason }}</text>
				</view>
				<view v-if="orderDetail.cancelTime" class="info-row">
					<text class="info-label">取消时间</text>
					<text class="info-value">{{ formatDateTime(orderDetail.cancelTime) }}</text>
				</view>
			</view>
			
			<!-- 套餐信息卡片 -->
			<view class="info-card">
				<view class="section-header">
					<text class="section-title">套餐信息</text>
				</view>
				<view class="info-row">
					<text class="info-label">套餐类型</text>
					<text class="info-value">{{ getPkgCategoryText() }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">套餐流量</text>
					<text class="info-value">{{ getPkgFlowText() }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">有效期</text>
					<text class="info-value">{{ orderDetail.validityPeriod || '-' }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">生效时间</text>
					<text class="info-value">{{ formatDateTime(orderDetail.startDate) || '--' }}</text>
				</view>
				<view class="info-row">
					<text class="info-label">失效时间</text>
					<text class="info-value">{{ formatDateTime(orderDetail.endDate) || '--' }}</text>
				</view>
			</view>
			
			<!-- 说明卡片 -->
			<view v-if="orderDetail.usageInstructions || getNoticeText()" class="notice-card">
				<view class="section-header">
					<text class="section-title">说明</text>
				</view>
				<text class="notice-text">{{ orderDetail.usageInstructions || getNoticeText() }}</text>
			</view>
			
			<!-- 底部占位 -->
			<view class="bottom-placeholder"></view>
		</scroll-view>
		
		<!-- 底部支付栏（仅待支付状态显示） -->
		<view v-if="orderDetail.status === '0'" class="bottom-bar">
			<view class="amount-section">
				<text class="amount-label">待支付金额</text>
				<text class="amount-value">¥{{ orderDetail.payAmount || orderDetail.orderAmount || 0 }}</text>
			</view>
			<view class="pay-button" @click="choosePayment">
				<text class="pay-button-text">去支付</text>
			</view>
		</view>
	</view>
	<rice-popup
		v-model:show="showPopup"
		position="bottom"
		@close="onPopupClose"
	>
		<Payment 
			:amount="currentPrice" 
			@cancel="handleCancelPayment"
			@confirm="handleConfirmPayment"
		/>
	</rice-popup>
</template>

<script setup lang="uts">
	import { addOrderXcx , queryOrderDetailXcx } from '@/api/http.uts';
	import Payment from '@/components/payment.uvue';
	
	const showPopup = ref(false);
	const currentPrice = ref(0);
	const orderId = ref('');
	const orderDetail = ref<any>({
		orderNo: '',
		rechargeNo: '',
		pkgName: '',
		pkgCategory: '',
		pkgType: '',
		pkgFlow: 0,
		validityPeriod: '',
		startDate: '',
		endDate: '',
		status: '',
		pkgRefundStatus: '',
		orderAmount: 0,
		payAmount: 0,
		orderCreateTime: '',
		payTime: '',
		refunds: [],
		cancelTime: '',
		payFailTime: '',
		payFailReason: '',
		usageInstructions: '',
		currentSeconds: 0
	});
	
	// 获取订单状态文本
	const getOrderStatusText = (): string => {
		const status = orderDetail.value.status;
		switch (status) {
			case '0':
				return '待支付'
			case '1':
				return '已完成'
			case '2':
				return '已退款'
			case '3':
				return '已取消'
			default:
				return '未知状态'
		}
	}
	
	// 获取状态样式类
	const getStatusClass = (status: string): string => {
		switch (status) {
			case '已完成':
				return 'status-completed'
			case '待支付':
				return 'status-pending'
			case '已退款':
				return 'status-refunded'
			case '已取消':
				return 'status-cancelled'
			default:
				return ''
		}
	}
	
	// 获取套餐类型文本
	const getPkgCategoryText = (): string => {
		const category = orderDetail.value.pkgCategory;
		switch (category) {
			case '1':
				return '套餐包'
			case '2':
				return '加油包'
			default:
				return orderDetail.value.pkgCategory || '-'
		}
	}
	
	// 获取套餐流量文本
	const getPkgFlowText = (): string => {
		const flow = orderDetail.value.pkgFlow;
		if (!flow && flow !== 0) return '-';
		
		// 根据套餐类型判断单位
		const pkgType = orderDetail.value.pkgType;
		if (flow >= 1024) {
			return `${(flow / 1024).toFixed(2)}GB`;
		}
		return `${flow}MB`;
	}
	
	// 获取支付方式
	const getPaymentMethod = (): string => {

		return '微信小程序支付'







		return '微信支付'
	}
	
	// 获取说明文本
	const getNoticeText = (): string => {
		const status = orderDetail.value.status;
		switch (status) {
			case '0':
				return '订单尚未支付，支付完成后套餐才会生效。'
			case '1':
				return '套餐已生效，可在有效期内使用。'
			case '2':
				return '订单已退款，金额将原路返回。'
			case '3':
				return '订单已取消。'
			default:
				return ''
		}
	}
	
	// 格式化日期时间（不转换时区，直接显示原值）
	const formatDateTime = (dateTime: string): string => {
		if (!dateTime) return ''
		// 如果是 ISO 格式，提取前面部分
		if (dateTime.includes('T')) {
			return dateTime.replace('T', ' ').substring(0, 19)
		}
		return dateTime
	}
	
	// 选择支付方式
	const choosePayment = () => {
		currentPrice.value = orderDetail.value.payAmount || orderDetail.value.orderAmount || 0
		showPopup.value = true
	}
	
	// 取消支付
	const handleCancelPayment = () => {
		showPopup.value = false
	}
	
	// 确认支付
	const handleConfirmPayment = async (e: any) => {
		uni.__f__('log','at pages/orderDetail/orderDetail.uvue:264',e)
		try {
			const res = await addOrderXcx({
				pkgId: orderDetail.value.pkgId,
				rechargeNo: orderDetail.value.rechargeNo,
			})
			if (res.code == 200) {
				uni.showToast({
					title: '支付成功',
					icon: 'success'
				})
				// 刷新订单详情
				await getOrderDetail()
			} else {
				uni.showToast({
					title: res.msg || '支付失败',
					icon: 'none'
				})
			}
		} catch (error) {
			uni.__f__('error','at pages/orderDetail/orderDetail.uvue:284','支付失败:', error)
			uni.showToast({
				title: '支付失败，请稍后重试',
				icon: 'none'
			})
		}
		showPopup.value = false
	}
	
	// 支付弹窗关闭
	const onPopupClose = () => {
		showPopup.value = false
	}
	
	// 返回上一页
	const handleBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}
	
	// 查询订单详情
	const getOrderDetail = async () => {
		if (!orderId.value) return
		try {
			const res = await queryOrderDetailXcx(orderId.value)
			if (res.code == 200) {
				orderDetail.value = res.data
				uni.__f__('log','at pages/orderDetail/orderDetail.uvue:312','订单详情:', orderDetail.value)
			} else {
				uni.showToast({
					title: res.msg || '查询订单详情失败',
					icon: 'none'
				})
			}
		} catch (error) {
			uni.__f__('error','at pages/orderDetail/orderDetail.uvue:320','查询订单详情失败:', error)
			uni.showToast({
				title: '网络错误，请稍后重试',
				icon: 'none'
			})
		}
	}
	
	onLoad((options) => {
		const orderNo = options?.orderNo as string | null
		uni.__f__('log','at pages/orderDetail/orderDetail.uvue:330',orderNo)
		if (orderNo != null) {
			orderId.value = orderNo
			getOrderDetail()
		}
	})
</script>

