<template>
	<view style="height: 100%;">
		<topNavBar title="и®ўеҚ•иҜҰжғ…" @back="handleBack" :show-back="true" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
		<scroll-view class="container" scroll-y :enhanced="true">
			<!-- еҘ—йӨҗеҗҚз§°еҚЎзүҮ -->
			<view class="package-card">
				<view class="package-header" v-if="orderDetail.pkgName">
					<text class="package-name">{{ orderDetail.pkgName }}</text>
					<rice-tag 
						:type="getOrderStatusType(orderDetail.status)" 
						:text="getOrderStatusText(orderDetail.status)" 
						:round="true" 
						plain-fill 
						size="small"
					></rice-tag>
				</view>
				<view class="card-number-row" v-if="orderDetail.rechargeNo">
					<text class="card-number-label">еҪ“еүҚеҚЎеҸ·пјҡ</text>
					<text class="card-number">{{ orderDetail.rechargeNo }}</text>
				</view>
			</view>
			
			<!-- и®ўеҚ•дҝЎжҒҜеҚЎзүҮ -->
			<view class="info-card">
				<view class="info-row" v-if="orderDetail.orderNo">
					<text class="info-label">и®ўеҚ•зј–еҸ·</text>
					<text class="info-value">{{ orderDetail.orderNo }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.iccid">
					<text class="info-label">ICCID</text>
					<text class="info-value">{{ orderDetail.iccid }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.orderAmount">
					<text class="info-label">ж”Ҝд»ҳйҮ‘йўқ</text>
					<text class="info-value price">ВҘ{{ orderDetail.payAmount || orderDetail.orderAmount || 0 }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.orderStatus">
					<text class="info-label">и®ўеҚ•зҠ¶жҖҒ</text>
					<text class="info-value status">{{ getOrderStatusText(orderDetail.status) }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.payMethod">
					<text class="info-label">ж”Ҝд»ҳж–№ејҸ</text>
					<text class="info-value">{{ getPaymentMethod() }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.orderCreateTime">
					<text class="info-label">дёӢеҚ•ж—¶й—ҙ</text>
					<text class="info-value">{{ formatDateTime(orderDetail.orderCreateTime) }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.payTime">
					<text class="info-label">ж”Ҝд»ҳж—¶й—ҙ</text>
					<text class="info-value">{{ formatDateTime(orderDetail.payTime)}}</text>
				</view>
				<view v-if="orderDetail.payFailReason" class="info-row">
					<text class="info-label">ж”Ҝд»ҳеӨұиҙҘеҺҹеӣ </text>
					<text class="info-value status-fail">{{ orderDetail.payFailReason }}</text>
				</view>
				<view v-if="orderDetail.cancelTime" class="info-row">
					<text class="info-label">еҸ–ж¶Ҳж—¶й—ҙ</text>
					<text class="info-value">{{ formatDateTime(orderDetail.cancelTime) }}</text>
				</view>
			</view>
			
			<!-- еҘ—йӨҗдҝЎжҒҜеҚЎзүҮ -->
			<view class="info-card">
				<view class="section-header">
					<text class="section-title">еҘ—йӨҗдҝЎжҒҜ</text>
				</view>
				<view class="info-row" v-if="orderDetail.pkgCategory">
					<text class="info-label">еҘ—йӨҗзұ»еһӢ</text>
					<text class="info-value">{{ getPkgCategoryText() }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.pkgFlow">
					<text class="info-label">еҘ—йӨҗжөҒйҮҸ</text>
					<text class="info-value">{{ getPkgFlowText() }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.validityPeriod">
					<text class="info-label">жңүж•Ҳжңҹ</text>
					<text class="info-value">{{ orderDetail.validityPeriod }}{{ orderDetail?.pkgType == '1' ? 'еӨ©' : 'дёӘжңҲ' }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.startDate">
					<text class="info-label">з”ҹж•Ҳж—¶й—ҙ</text>
					<text class="info-value">{{ formatDateTime(orderDetail.startDate) }}</text>
				</view>
				<view class="info-row" v-if="orderDetail.endDate">
					<text class="info-label">еӨұж•Ҳж—¶й—ҙ</text>
					<text class="info-value">{{ formatDateTime(orderDetail.endDate)}}</text>
				</view>
				<rice-divider v-if="orderDetail.refunds && orderDetail.refunds.length > 0" dashed :customStyle="{margin: '0'}"></rice-divider>
				<view class="info-refunds" v-if="orderDetail.refunds && orderDetail.refunds.length > 0" v-for="(item, index) in orderDetail.refunds" :key="index">
					<view class="times">
						<text class="info-label">йҖҖж¬ҫж—¶й—ҙ</text>
						<text class="info-value">{{ formatDateTime(item.refundTime)}}</text>
					</view>
					<view class="money">
						<text class="info-label">йҖҖж¬ҫйҮ‘йўқ</text>
						<text class="info-value">ВҘ{{ item.refundAmount || 0 }}</text>
					</view>
				</view>
			</view>
			
			<!-- иҜҙжҳҺеҚЎзүҮ -->
			<view v-if="orderDetail.usageInstructions || getNoticeText()" class="notice-card">
				<view class="section-header">
					<text class="section-title">иҜҙжҳҺ</text>
				</view>
				<text class="notice-text">{{ orderDetail.usageInstructions || getNoticeText() }}</text>
			</view>
			
			<!-- еә•йғЁеҚ дҪҚ -->
			<view class="bottom-placeholder"></view>
		</scroll-view>
		
		<!-- еә•йғЁж”Ҝд»ҳж ҸпјҲд»…еҫ…ж”Ҝд»ҳзҠ¶жҖҒжҳҫзӨәпјү -->
		<view v-if="orderDetail.status === '0'" class="bottom-bar">
			<view class="amount-section">
				<text class="amount-label">еҫ…ж”Ҝд»ҳйҮ‘йўқ</text>
				<text class="amount-value">ВҘ{{ orderDetail.payAmount || orderDetail.orderAmount || 0 }}</text>
			</view>
			<view class="amount-time">
				<text class="amount-label">ж”Ҝд»ҳеү©дҪҷж—¶й—ҙ</text>
				<rice-count-down :time="orderDetail.currentSeconds * 1000 || 0" font-size="28rpx" color="#f56c6c" @finish="handleCountDownFinish"/>
			</view>
			<view class="pay-button" @click="choosePayment">
				<text class="pay-button-text">еҺ»ж”Ҝд»ҳ</text>
			</view>
		</view>
	</view>
	<rice-popup
		v-model:show="showPopup"
		position="bottom"
		@close="onPopupClose"
	>
		<Payment 
			:amount="currentPrice" 
			@cancel="handleCancelPayment"
			@confirm="handleConfirmPayment"
			:cardNumber="orderDetail.rechargeNo",
			:productName="orderDetail.pkgName"
			:traffic="orderDetail.pkgFlow"
			:validityPeriod="orderDetail.validityPeriod"
		/>
	</rice-popup>
</template>

<script setup lang="uts">
	import { goPayXcx , queryOrderDetail } from '@/api/http';
	import { config } from '@/common/config.uts';
	import Payment from '@/components/payment.uvue';
	
	const showPopup = ref(false);
	const currentPrice = ref(0);
	const orderId = ref('');
	const payChannelId = ref('');
	const orderDetail = ref<any>({
		orderNo: '',
		rechargeNo: '',
		pkgName: '',
		pkgCategory: '',
		pkgType: '',
		pkgFlow: 0,
		validityPeriod: '',
		startDate: '',
		endDate: '',
		status: '',
		pkgRefundStatus: '',
		orderAmount: 0,
		payAmount: 0,
		orderCreateTime: '',
		payTime: '',
		refunds: [],
		cancelTime: '',
		payFailTime: '',
		payFailReason: '',
		usageInstructions: '',
		currentSeconds: 0
	});

		// иҺ·еҸ–и®ўеҚ•зҠ¶жҖҒеҜ№еә”зҡ„ж–Үжң¬
	const getOrderStatusText = (status: string): string => {
		const statusMap: Record<string, string> = {
			'0': 'еҫ…ж”Ҝд»ҳ',
			'1': 'е·Іе®ҢжҲҗ',
			'2': 'е·ІеҸ–ж¶Ҳ',
			'3': 'ж”Ҝд»ҳеӨұиҙҘ',
			'4': 'йғЁеҲҶйҖҖж¬ҫ',
			'5': 'е…ЁйғЁйҖҖж¬ҫ',
		}
		return statusMap[status] || status || 'жңӘзҹҘ'
	}

	// иҺ·еҸ–и®ўеҚ•зҠ¶жҖҒеҜ№еә”зҡ„ж Үзӯҫзұ»еһӢ
	const getOrderStatusType = (status: string): string => {
		const typeMap: Record<string, string> = {
			'0': 'primary',
			'1': 'success',
			'2': 'error',
			'3': 'danger',
			'4': 'warning',
			'5': 'warning',
		}
		return typeMap[status] || 'primary'
	}
	
	// иҺ·еҸ–еҘ—йӨҗзұ»еһӢж–Үжң¬
	const getPkgCategoryText = (): string => {
		const category = orderDetail.value.pkgCategory;
		switch (category) {
			case '1':
				return 'еҘ—йӨҗеҢ…'
			case '2':
				return 'еҠ жІ№еҢ…'
			default:
				return orderDetail.value.pkgCategory || '-'
		}
	}
	
	// иҺ·еҸ–еҘ—йӨҗжөҒйҮҸж–Үжң¬
	const getPkgFlowText = (): string => {
		const flow = orderDetail.value.pkgFlow;
		if (!flow && flow !== 0) return '-';
		
		// ж №жҚ®еҘ—йӨҗзұ»еһӢеҲӨж–ӯеҚ•дҪҚ
		const pkgType = orderDetail.value.pkgType;
		if (flow >= 1024) {
			return `${(flow / 1024).toFixed(2)}GB`;
		}
		return `${flow}MB`;
	}
	
	// иҺ·еҸ–ж”Ҝд»ҳж–№ејҸ
	const getPaymentMethod = (): string => {

		return 'еҫ®дҝЎе°ҸзЁӢеәҸж”Ҝд»ҳ'







		return 'еҫ®дҝЎж”Ҝд»ҳ'
	}
	
	// иҺ·еҸ–иҜҙжҳҺж–Үжң¬
	const getNoticeText = (): string => {
		const status = orderDetail.value.status;
		switch (status) {
			case '0':
				return 'и®ўеҚ•е°ҡжңӘж”Ҝд»ҳпјҢж”Ҝд»ҳе®ҢжҲҗеҗҺеҘ—йӨҗжүҚдјҡз”ҹж•ҲгҖӮ'
			case '1':
				return 'еҘ—йӨҗе·Із”ҹж•ҲпјҢеҸҜеңЁжңүж•ҲжңҹеҶ…дҪҝз”ЁгҖӮ'
			case '2':
				return 'и®ўеҚ•е·ІйҖҖж¬ҫпјҢйҮ‘йўқе°ҶеҺҹи·Ҝиҝ”еӣһгҖӮ'
			case '3':
				return 'и®ўеҚ•е·ІеҸ–ж¶ҲгҖӮ'
			default:
				return ''
		}
	}
	
	// ж јејҸеҢ–ж—Ҙжңҹж—¶й—ҙпјҲдёҚиҪ¬жҚўж—¶еҢәпјҢзӣҙжҺҘжҳҫзӨәеҺҹеҖјпјү
	const formatDateTime = (dateTime: string): string => {
		if (!dateTime) return ''
		// еҰӮжһңжҳҜ ISO ж јејҸпјҢжҸҗеҸ–еүҚйқўйғЁеҲҶ
		if (dateTime.includes('T')) {
			return dateTime.replace('T', ' ').substring(0, 19)
		}
		return dateTime
	}
	
	// йҖүжӢ©ж”Ҝд»ҳж–№ејҸ
	const choosePayment = () => {
		currentPrice.value = orderDetail.value.payAmount || orderDetail.value.orderAmount || 0
		showPopup.value = true
	}

	// еҖ’и®Ўж—¶з»“жқҹ
	const handleCountDownFinish = () => {
		uni.showToast({
			title: "ж”Ҝд»ҳе·ІиҝҮжңҹпјҢиҜ·йҮҚж–°дёӢеҚ•",
			icon: 'none',
			duration: 3000
		});
	}
	
	// еҸ–ж¶Ҳж”Ҝд»ҳ
	const handleCancelPayment = () => {
		showPopup.value = false
	}

	const toPay = (data:any) => {
		if(!data) return
		const res = data as any
		orderId.value = res.orderId
		payChannelId.value = res.payChannelId
		if(res.payWxType == 'wechat_pay'){
			uni.requestPayment({
				provider: 'wxpay',
				timeStamp: res.timeStamp,
				nonceStr: res.nonceStr,
				package: res.package,
				paySign: res.paySign,
				signType: res.signType,

				success: (res) => {
					uni.hideLoading()
					uni.showToast({
						title: "ж”Ҝд»ҳжҲҗеҠҹ",
						icon: 'success',
						duration: 3000,
					})
					uni.navigateTo({
						url: '/pages/paySuccess/paySuccess?orderId=' + orderId.value + '&payChannelId=' + payChannelId.value
					})
				},
				fail: (res) => {
					uni.hideLoading()
					uni.showToast({
						title: "ж”Ҝд»ҳеӨұиҙҘпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
						icon: 'none',
						duration: 3000
					});
					uni.navigateTo({
						url: '/pages/orderDetail/orderDetail?orderNo=' + orderId.value
					})
				},
			})
		}
		else if(res.payWxType == 'allin_pay'){
			if(res.payWxClass == '0'){
				uni.requestPayment({
					timeStamp: res.timeStamp,
					nonceStr: res.nonceStr,
					package: res.package,
					paySign: res.paySign,
					signType: res.signType,
					success: function (res) {
						uni.hideLoading()
						uni.showToast({
							title: "ж”Ҝд»ҳжҲҗеҠҹ",
							icon: 'success',
							duration: 3000,
							success() {
								uni.navigateTo({
									url: '/pages/paySuccess/paySuccess?orderId=' + orderId.value + '&payChannelId=' + payChannelId.value
								})
							}
						});
					},
					fail: function (err) {
						uni.hideLoading()
						uni.showToast({
							title: "ж”Ҝд»ҳеӨұиҙҘпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
							icon: 'none',
							duration: 3000
						});
						uni.navigateTo({
						url: '/pages/orderDetail/orderDetail?orderNo=' + orderId.value
					})
					},
				});
			}else{
				let param = {
					cusid: res.cusid,
					appid: res.appid,
					orgid: res.orgid,
					version: res.version,
					trxamt: res.trxamt,
					reqsn: res.reqsn,
					notify_url: res.notify_url,
					body: res.body,
					remark: res.remark,
					randomstr: res.randomstr,
					paytype: res.paytype,
					signtype: res.signtype,
					sign: res.sign,
				}

				uni.navigateToMiniProgram({
					appId: config.api.auth.appID,
					extraData: param,
					success(res) { 
						uni.navigateTo({
							url: '/pages/paySuccess/paySuccess?orderId=' + orderId.value + '&payChannelId=' + payChannelId.value
						})
					},
					fail(res) {
						uni.hideLoading()
						uni.showToast({
							title: "ж”Ҝд»ҳеҸ–ж¶ҲпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
							icon: 'none',
							duration: 3000
						});
						uni.navigateTo({
							url: '/pages/orderDetail/orderDetail?orderNo=' + orderId.value
						})
					}
				})
			}
		}
	}
	
	// зЎ®и®Өж”Ҝд»ҳ
	const handleConfirmPayment = async (e: any) => {
		showPopup.value = false
		try {
			const res = await goPayXcx(orderId.value)
			if (res.code == 200) {
				toPay(res.data)
			} else {
				uni.showToast({
					title: res.msg || 'ж”Ҝд»ҳеӨұиҙҘ',
					icon: 'none'
				})
			}
		} catch (error) {
			uni.__f__('error','at pages/orderDetail/orderDetail.uvue:417','ж”Ҝд»ҳеӨұиҙҘ:', error)
			uni.showToast({
				title: 'ж”Ҝд»ҳеӨұиҙҘпјҢиҜ·зЁҚеҗҺйҮҚиҜ•',
				icon: 'none'
			})
		}
	}
	
	// ж”Ҝд»ҳеј№зӘ—е…ій—ӯ
	const onPopupClose = () => {
		showPopup.value = false
	}
	
	// иҝ”еӣһдёҠдёҖйЎө
	const handleBack = () => {
		uni.navigateBack()
	}
	
	// жҹҘиҜўи®ўеҚ•иҜҰжғ…
	const getOrderDetail = async () => {
		if (!orderId.value) return
		try {
			const res = await queryOrderDetail(orderId.value)
			if (res.code == 200) {
				orderDetail.value = res.data
			} else {
				uni.showToast({
					title: res.msg || 'жҹҘиҜўи®ўеҚ•иҜҰжғ…еӨұиҙҘ',
					icon: 'none'
				})
			}
		} catch (error) {
			uni.__f__('error','at pages/orderDetail/orderDetail.uvue:449','жҹҘиҜўи®ўеҚ•иҜҰжғ…еӨұиҙҘ:', error)
			uni.showToast({
				title: 'зҪ‘з»ңй”ҷиҜҜпјҢиҜ·зЁҚеҗҺйҮҚиҜ•',
				icon: 'none'
			})
		}
	}
	
	onLoad((options) => {
		const orderNo = options?.orderNo as string | null
		if (orderNo != null) {
			orderId.value = orderNo
			getOrderDetail()
		}
	})

	onShow(() => {
		let options = uni.getEnterOptionsSync();
		if (options.scene == '1038' &&
			options.referrerInfo.appId == config.api.auth.appID) {
			// д»ЈиЎЁд»Һж”¶й“¶еҸ°е°ҸзЁӢеәҸиҝ”еӣһ
			let extraData = options.referrerInfo.extraData;
			if (!extraData) {
				// "еҪ“еүҚйҖҡиҝҮзү©зҗҶжҢүй”®иҝ”еӣһпјҢжңӘжҺҘж”¶еҲ°иҝ”еҸӮпјҢе»әи®®иҮӘиЎҢжҹҘиҜўдәӨжҳ“з»“жһң";
				uni.hideLoading()
				uni.showToast({
					title: "ж”Ҝд»ҳеҸ–ж¶ҲпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
					icon: 'none',
					duration: 3000
				});
				return
			} else {
				if (extraData.code == 'success') {
					uni.hideLoading()
					uni.showToast({
						title: "ж”Ҝд»ҳжҲҗеҠҹ",
						icon: 'success',
						duration: 3000,
						success() {
							uni.navigateBack({
								delta: 1
							})
						}
					});
					// "ж”Ҝд»ҳжҲҗеҠҹ";
				} else if (extraData.code == 'cancel') {
					uni.hideLoading()
					uni.showToast({
						title: "ж”Ҝд»ҳеҸ–ж¶ҲпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
						icon: 'none',
						duration: 3000
					});
					return
				} else {
					uni.hideLoading()
					uni.showToast({
						title: "ж”Ҝд»ҳеӨұиҙҘпјҢиҜ·жӮЁйҮҚж–°ж”Ҝд»ҳ",
						icon: 'none',
						duration: 3000
					});
					return
				}
			}
		}
	})
</script>

<style lang="scss" scoped>
	.container {
		background-color: #f4f7fb;
		height: 100%;
		padding: 24rpx;
		box-sizing: border-box;
	}
	
	// еҘ—йӨҗеҗҚз§°еҚЎзүҮ
	.package-card {
		background-color: #ffffff;
		border-radius: 24rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
		
		.package-header {
			display: flex;
			flex-direction: row; 
			justify-content: space-between;
			align-items: center;
			margin-bottom: 16rpx;
			
			.package-name {
				font-size: 36rpx;
				font-weight: 600;
				color: #1f2937;
			}
			
			.status-tag {
				font-size: 24rpx;
				padding: 6rpx 16rpx;
				border-radius: 20rpx;
				font-weight: 500;
				
				&.status-pending {
					background-color: #fff3e0;
					color: #ed6c02;
				}
				
				&.status-completed {
					background-color: #e8f5e9;
					color: #2e7d32;
				}
				
				&.status-refunded {
					background-color: #fce4ec;
					color: #c62828;
				}
				
				&.status-cancelled {
					background-color: #eeeeee;
					color: #757575;
				}
