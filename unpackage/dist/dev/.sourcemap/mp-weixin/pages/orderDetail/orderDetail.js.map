				font-size: 28rpx;
				color: #9ca3af;
			}
			
			.card-number {
				font-size: 28rpx;
				color: #374151;
				font-weight: 500;
			}
		}
	}
	
	// 信息卡片通用样式
	.info-card {
		background-color: #ffffff;
		border-radius: 24rpx;
		padding: 32rpx;
		margin-bottom: 24rpx;
		
		.section-header {
			margin-bottom: 24rpx;
			padding-bottom: 20rpx;
			border-bottom: 1rpx solid #f0f2f6;
			
			.section-title {
				font-size: 32rpx;
				font-weight: 600;
				color: #1f2937;
			}
		}
		
		.info-row {
			display: flex;
			flex-direction: row; 
			justify-content: space-between;
			align-items: center;
			padding: 20rpx 0;
			
			.info-label {
				font-size: 28rpx;
				color: #64748b;
			}
			
			.info-value {
				font-size: 28rpx;
				color: #374151;
				text-align: right;
				
				&.price {
					font-size: 36rpx;
					font-weight: bold;
					color: #ef4444;
				}
				
				&.status-fail {
					color: #ef4444;
				}
			}
		}
		.info-refunds{
			display: flex;
			flex-direction: column; 
			padding: 20rpx 0;
			.times,
			.money{
				display: flex;
				flex-direction: row; 
				align-items: center;
				justify-content: space-between;
				margin:10rpx 0;
				font-size: 24rpx;
				color: #64748b;
			}
		}
	}
	
	
	// 底部占位
	.bottom-placeholder {
		height: 140rpx;
	}
	
	// 底部支付栏
	.bottom-bar {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		background-color: #ffffff;
		display: flex;
		flex-direction: row; 
		justify-content: space-between;
		align-items: center;
		padding: 24rpx 32rpx;
		box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
		
		.amount-section {
			display: flex;
			flex-direction: column; 
