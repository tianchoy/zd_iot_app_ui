<script setup lang="uts">
	import { queryOrderDetailXcx } from '@/api/http.uts';
	import Payment from '@/components/payment.uvue';
	const showPopup = ref(false);
	const currentPrice = ref(50);
	const orderId = ref('');
	
	const getStatusClass = (status: string): string => {
		switch (status) {
			case 'е·Іе®ҢжҲҗ':
				return 'status-completed'
			case 'еҫ…ж”Ҝд»ҳ':
				return 'status-pending'
			case 'е·ІйҖҖж¬ҫ':
				return 'status-refunded'
			case 'е·ІеҸ–ж¶Ҳ':
				return 'status-cancelled'
			default:
				return ''
		}
	}
	
	// йҖүжӢ©ж”Ҝд»ҳж–№ејҸ
	const choosePayment = () => {
		showPopup.value = true;
	}

	// еҸ–ж¶Ҳж”Ҝд»ҳ
	const handleCancelPayment = () => {
		showPopup.value = false;
	}

	// зЎ®и®Өж”Ҝд»ҳ
	const handleConfirmPayment = (e: any) => {
		uni.__f__('log','at pages/orderDetail/orderDetail.uvue:138',e);
		// еӨ„зҗҶзЎ®и®ӨйҖ»иҫ‘
		showPopup.value = false;
	}

	// иҝ”еӣһдёҠдёҖйЎө
	const handleBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}

	// жҹҘиҜўи®ўеҚ•иҜҰжғ…
	const getOrderDetail = async () => {
		try {
			const res = await queryOrderDetailXcx(orderId.value);
			if (res.code == 200) {
				// еӨ„зҗҶи®ўеҚ•иҜҰжғ…ж•°жҚ®
				uni.__f__('log','at pages/orderDetail/orderDetail.uvue:156',res.data);
			}
		} catch (error) {
			uni.__f__('error','at pages/orderDetail/orderDetail.uvue:159','жҹҘиҜўи®ўеҚ•иҜҰжғ…еӨұиҙҘ:', error);
		}
	}
	
	onLoad((options)=>{
		uni.__f__('log','at pages/orderDetail/orderDetail.uvue:164',options);
		orderId.value = options.orderNo;
		getOrderDetail()
	})
</script>

