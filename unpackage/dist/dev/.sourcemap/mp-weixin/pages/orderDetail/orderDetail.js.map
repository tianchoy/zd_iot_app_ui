				border-radius: 20rpx;
				font-weight: 500;
				
				&.status-pending {
					background-color: #fff3e0;
					color: #ed6c02;
				}
				
				&.status-completed {
					background-color: #e8f5e9;
					color: #2e7d32;
				}
				
				&.status-refunded {
					background-color: #fce4ec;
					color: #c62828;
				}
				
				&.status-cancelled {
					background-color: #eeeeee;
