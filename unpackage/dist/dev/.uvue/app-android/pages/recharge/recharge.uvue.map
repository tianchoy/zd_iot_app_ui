<template>
	<topNavBar title="充值首页" :show-back="true" @back="goBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<view class="card-info">
			<view class="card-title">
				<text class="title">卡片信息</text>
				<m-tag text="标签" :round="true" :plain="true" size="small" type="primary"></m-tag>
			</view>
			<view class="card-number">
				<text>1234567890123456</text>
			</view>
			<view class="info-list">
				<view class="info-item">
					<text class="label">当前套餐</text>
					<text class="value">车联网月包20G（名称较长时自动换行展示）</text>
				</view>
				<view class="info-item">
					<text class="label">卡片余额</text>
					<text class="value">¥1000.00</text>
				</view>
			</view>
			<view class="flow-box">
				<view class="flow-label">充值成功</view>
				<LinearProgress :value="progress1" />
			</view>
			<view class="card-bottom">
				<m-button type="white" :plain="true" :margin="'0 20rpx'" height="70rpx" shape="circle" :bold="true" @click="toMyPackage">卡片套餐</m-button>
				<m-button type="white" :plain="true" :margin="'0 20rpx'" height="70rpx" shape="circle" :bold="true" @click="toOrderRecord">订单记录</m-button>
			</view>
		</view>
		<view class="pkg-box">
			<m-tabs 
			:tabs="tabs" 
			width="100rpx" 
			:padding="0"
			:isSlider="true" 
			:currentTab="active" 
			@change="changeTab" 
			:unlined="false" 
			:bold="true"
			/>
			<view class="pkg-content">
				<!-- 套餐包列表 -->
				<block v-if="active === 0">
					<view 
						v-for="(item, index) in packageList" 
						:key="index" 
						class="pkg-card"
						:class="{ 'pkg-card-selected': selectedPackageIndex === index }"
						@click="selectPackage(index)"
					>
						<view class="pkg-info">
							<view class="pkg-name">
								<text class="pkg-title">{{ item.name }}</text>
								<text v-if="item.tag" class="pkg-tag">{{ item.tag }}</text>
							</view>
							<view class="pkg-desc">
								<text class="pkg-icon">流量 {{ item.data }}</text>
								<text class="pkg-icon">有效期 {{ item.validity }}</text>
							</view>
						</view>
						<view class="pkg-price">
							<view class="price-wrapper">
								<text class="price-symbol">¥</text>
								<text class="price-number">{{ item.price }}</text>
							</view>
							<view class="price-original" v-if="item.originalPrice">
								<text>¥{{ item.originalPrice }}</text>
							</view>
						</view>
					</view>
				</block>
				<!-- 加油包列表 -->
				<block v-else>
					<view 
						v-for="(item, index) in refillList" 
						:key="index" 
						class="pkg-card"
						:class="{ 'pkg-card-selected': selectedRefillIndex === index }"
						@click="selectRefill(index)"
					>
						<view class="pkg-info">
							<view class="pkg-name">
								<text class="pkg-title">{{ item.name }}</text>
								<text v-if="item.tag" class="pkg-tag">{{ item.tag }}</text>
							</view>
							<view class="pkg-desc">
								<text class="pkg-icon">流量 {{ item.data }}</text>
								<text class="pkg-icon">有效期 {{ item.validity }}</text>
							</view>
						</view>
						<view class="pkg-price">
							<view class="price-wrapper">
								<text class="price-symbol">¥</text>
								<text class="price-number">{{ item.price }}</text>
							</view>
							<view class="price-original" v-if="item.originalPrice">
								<text>¥{{ item.originalPrice }}</text>
							</view>
						</view>
					</view>
				</block>
			</view>
		</view>
	</view>
	<m-bottom-popup
		:show="showPopup"




		:height="'75%'"

		:radius="true"
		@close="showPopup = false"
	>
		<Payment 
			:amount="currentPrice" 
			@cancel="handleCancelPayment"
			@confirm="handleConfirmPayment"
		/>
	</m-bottom-popup>
	<m-sticky-bottom>
		<view class="bottom-box">
			<view class="price-box">
				<text class="price-label">当前套餐金额</text>
				<text class="price-value">¥{{ currentPrice }}</text>
			</view>
			<m-button type="primary" @click="choosePayment" :plain="false" :margin="'0 20rpx'" width="200rpx" height="70rpx" shape="circle" :bold="true" :shadow="false">去支付</m-button>
		</view>
	</m-sticky-bottom>
</template>

<script setup lang="uts">
	import { ref, computed } from 'vue';
	import LinearProgress from '@/components/progress.uvue';
	import Payment from '@/components/payment.uvue';
	
	// Tab 项类型
	type TabItem = {
		name: string;
	};
	
	// 套餐包/加油包项类型
	type PackageItem = {
		name: string;
		tag: string;
		data: string;
		validity: string;
		price: number;
		originalPrice: number;
	};
	
	// changeTab 函数的参数类型
	type ChangeTabEvent = {
		index: number;
	};
	
	const showPopup = ref<boolean>(false);
	const progress1 = ref<number>(80);
	
	const active = ref<number>(0);
	const tabs = ref<Array<TabItem>>([
		{
			name: '套餐包'
		},
		{
			name: '加油包',
		}
	]);
	
	// 套餐包列表数据
	const packageList = ref<Array<PackageItem>>([
		{
			name: '车联网月包20G',
			tag: '推荐',
			data: '20GB',
			validity: '30天',
			price: 90,
			originalPrice: 100
		},
		{
			name: '车联网月包10G',
			tag: '',
			data: '10GB',
			validity: '30天',
			price: 50,
			originalPrice: 0
		},
		{
			name: '工业设备月包5G',
			tag: '',
			data: '5GB',
			validity: '30天',
			price: 30,
			originalPrice: 0
		}
	]);
	
	// 加油包列表数据
	const refillList = ref<Array<PackageItem>>([
		{
			name: '加油包5G',
			tag: '推荐',
			data: '5GB',
			validity: '7天',
			price: 20,
			originalPrice: 30
		},
		{
			name: '加油包10G',
			tag: '',
			data: '10GB',
			validity: '15天',
			price: 35,
			originalPrice: 45
		},
		{
			name: '加油包20G',
			tag: '',
			data: '20GB',
			validity: '30天',
			price: 60,
			originalPrice: 80
		}
	]);
	
	// 选中的套餐包索引
	const selectedPackageIndex = ref<number>(0);
	// 选中的加油包索引
	const selectedRefillIndex = ref<number>(0);
	
	const currentPrice = computed<number>((): number => {
		if (active.value === 0) {
			const item = packageList.value[selectedPackageIndex.value];
			return item ? item.price : 0;
		} else {
			const item = refillList.value[selectedRefillIndex.value];
			return item ? item.price : 0;
		}
	});
	
	const changeTab = (e: ChangeTabEvent) => {
		active.value = e.index;
	}
	
	const selectPackage = (index: number) => {
		selectedPackageIndex.value = index;
	}
	
	const selectRefill = (index: number) => {
		selectedRefillIndex.value = index;
	}
	
	// 选择支付方式
	const choosePayment = () => {
		showPopup.value = true;
	}
	
	// 取消支付
	const handleCancelPayment = () => {
		showPopup.value = false;
	}
	
	// 确认支付
	const handleConfirmPayment = (e: any) => {
		console.log(e);
		// 处理确认逻辑
		showPopup.value = false;
	}
	
	const goBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}
	
	// 跳转我的套餐
	const toMyPackage = () => {
		uni.navigateTo({
			url: '/pages/myPkg/myPkg'
		})
	}
	
	// 跳转订单记录
	const toOrderRecord = () => {
		uni.navigateTo({
			url: '/pages/orderRecord/orderRecord'
		})
	}
	
</script>

