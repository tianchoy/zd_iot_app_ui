<template>
	<topNavBar title="套餐详情" :show-back="true" @back="handleBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
		<rice-overlay v-model:show="showLoading" mode="snow" bg-color="rgba(255, 255, 255, 0.4)">
			<rice-loading :customStyle="{height:'100rpx',width:'100rpx',position:'absolute',top:'50%',left:'50%',transform:'translate(-50%,-50%)'}" />
		</rice-overlay>
	<view class="container">
		<view class="card-box">
			<!-- 头部：套餐名称和状态 -->
			<view class="card-header">
				<text class="package-name" v-if="pkgInfo.pkgName">{{ pkgInfo.pkgName }}</text>
				<rice-tag v-if="pkgInfo.status" :text="pkgInfo.status" :round="true" plain-fill size="small" type="success"></rice-tag>
			</view>

			<!-- 卡号 -->
			<view class="card-number" v-if="pkgInfo.rechargeNo">
				<text class="number-label">当前卡号：</text>
				<text class="number-value">{{ pkgInfo.rechargeNo }}</text>
			</view>

			<!-- 流量使用进度 -->
			<view class="traffic-section" v-if="pkgInfo.usedFlow && pkgInfo.unUsedFlow">
				<view class="traffic-text">
					<view class="traffic-header">
						<text class="traffic-title">流量使用</text>
					</view>
					<view class="traffic-progress">
						<text class="used-text">已用{{ pkgInfo.usedFlow }} GB</text>
						<text class="divider">/</text>
						<text class="total-text">剩余{{ pkgInfo.unUsedFlow }} GB</text>
					</view>
				</view>

				<!-- 进度条 -->
				<view class="progress-bar"><rice-progress :percentage="flowPercentage" show-text /></view>
			</view>


			<!-- 套餐信息 -->
			<view class="info-grid">
				<view class="info-item" v-if="pkgInfo.pkgFlow">
					<text class="info-label">套餐流量</text>
					<text class="info-value">{{ pkgInfo.pkgFlow }} GB</text>
				</view>
				<view class="info-item" v-if="pkgInfo.startDate">
					<text class="info-label">生效时间</text>
					<text class="info-value">{{ pkgInfo.startDate }}</text>
				</view>
				<view class="info-item" v-if="pkgInfo.validityPeriod">
					<text class="info-label">有效期</text>
					<text class="info-value">{{ pkgInfo.validityPeriod }}{{ pkgInfo?.pkgType == '1' ? '天' : '个月' }}</text>
				</view>
				<view class="info-item" v-if="pkgInfo.endDate">
					<text class="info-label">到期时间</text>
					<text class="info-value">{{ pkgInfo.endDate }}</text>
				</view>
			</view>
		</view>

		<!-- 关联订单信息 -->
		<view class="card-box order-card">
			<view class="order-title">
				<text class="order-title-text">关联订单信息</text>
			</view>
			<view class="order-detail">
				<view class="order-row" v-if="pkgInfo.orderNo">
					<text class="order-label">关联订单号</text>
					<text class="order-value">{{ pkgInfo.orderNo }}</text>
				</view>
				<view class="order-row" v-if="pkgInfo.orderStatus">
					<text class="order-label">订单状态</text>
					<text class="order-value status-completed">{{ pkgInfo.orderStatus }}</text>
				</view>
				<view class="order-row" v-if="pkgInfo.payAmount">
					<text class="order-label">支付金额</text>
					<text class="order-value price">￥{{ pkgInfo.payAmount }}</text>
				</view>
				<view class="order-row" v-if="pkgInfo.orderCreateTime">
					<text class="order-label">下单时间</text>
					<text class="order-value">{{ pkgInfo.orderCreateTime }}</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import {queryPkgInfoXcx} from '@/api/http';
	import {ref, computed} from 'vue';

	const showLoading = ref(false)
	const pkgId = ref<string>('')
	// 查询套餐信息详情
	const pkgInfo = ref<any>({});

	const flowPercentage = computed(() => {
		if (!pkgInfo.value) return 0
		
		const usedFlow = Number(pkgInfo.value.usedFlow) || 0
		const pkgFlow = Number(pkgInfo.value.pkgFlow) || 0
		
		if (pkgFlow <= 0) return 0
		
		return Math.min((usedFlow / pkgFlow) * 100, 100)
	})
	// 初始化查询套餐信息详情
	const initPkgInfo = async () => {
		if (!pkgId.value) return
		showLoading.value = true
		try {
			const res = await queryPkgInfoXcx(pkgId.value)
			if (res.code == 200) {
				pkgInfo.value = res.data
				showLoading.value = false
			} else {
				showLoading.value = false
				uni.showToast({
					title: res.msg || '查询套餐信息详情失败',
					icon: 'none'
				})
			}
		} catch (error) {
			showLoading.value = false
			uni.showToast({
				title: '查询套餐信息详情失败',
				icon: 'none'
			})
		}
	}
		// 返回事件
	const handleBack = () => {
		// 处理返回逻辑
		uni.navigateBack()
	}

	onLoad((options)=>{
		console.log('pkgDetail onLoad',options)
		pkgId.value = options.pkgId ?? ''
		initPkgInfo()
	})
</script>

