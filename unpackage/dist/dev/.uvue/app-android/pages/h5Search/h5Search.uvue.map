<template>
	<topNavBar title="查询卡号" :show-back="false" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<view class="main-content">
			<!-- 标题区域 -->
			<view class="title-section">
				<text class="main-title">国内版H5快捷充值</text>
				<text class="sub-title">输入卡号，快速查询缴费</text>
				<text class="desc-text">支持短信链接、二维码、APP跳转进入H5页面，未登录</text>
				<text class="desc-text">也可直接充值。</text>
			</view>
			
			<!-- 卡号查询卡片 -->
			<view class="card-box">
				<view class="card-label">卡号查询</view>
				<view class="search-value">
					<input
						v-model="cardNumber"
						placeholder="请输入ICCID/MSISDN，或点击输入框右侧扫描图标识别卡号"
						class="search-input"
					/>
					<view class="scan-btn" @click="handleScan">
						<m-icon name="scanning" size="40rpx" color="#666"></m-icon>
					</view>
				</view>
				
				<!-- 选择国家/地区 -->
				<view class="select-country-wrapper">
					<view class="select-label">选择国家/地区</view>
					<view class="select-trigger" @tap="openSelectCountry">
						<text class="select-value" :class="{ placeholder: !selectedCountry }">
							{{ selectedCountryLabel || '请选择国家/地区' }}
						</text>
						<text class="select-arrow">▼</text>
					</view>
				</view>
				
				<view class="query-btn" @click="handleQuery">
					<text class="query-btn-text">查询缴费</text>
				</view>
			</view>
			
			<!-- 使用说明 -->
			<view class="instruction-box">
				<view class="instruction-title">使用说明</view>
				<view class="instruction-list">
					<text class="instruction-item">1.H5支持未登录快速充值。</text>
					<text class="instruction-item">2.APP跳转场景可直接进入充值首页，无需经过本入口页。</text>
					<text class="instruction-item">3.本原型用于展示H5页面结构及跳转关系。</text>
				</view>
			</view>
		</view>
	</view>
	
	<!-- 底部弹窗 -->
	<m-bottom-popup
		:show="showCountryPopup"




		:height="'75%'"

		:radius="true"
		@close="onPopupClose"
	>
		<view class="popup-header">
			<text class="popup-title">选择国家/地区</text>
			<view class="popup-close" @tap="onPopupClose">
				<m-icon name="close-bold" size="40rpx" ></m-icon>
			</view>
		</view>
		
		<SearchSelect
			ref="searchSelectRef"
			v-model="selectedCountry"
			:options="countryOptions"
			search-placeholder="搜索国家/地区名称"
			@change="onCountryChange"
		/>
	</m-bottom-popup>
</template>

<script setup lang="uts">
	import { ref, computed, onMounted, onUnmounted } from 'vue'
	import SearchSelect from '@/components/selectCountry.uvue'
	
	const cardNumber = ref<string>('1064916585160')
	
	// 国家/地区相关
	const showCountryPopup = ref<boolean>(false)
	const selectedCountry = ref<string>('')
	const searchSelectRef = ref<any>(null)
	
	// 国家/地区选项列表
	const countryOptions = ref([
		{ value: '1', label: '中国' },
		{ value: '2', label: '美国' },
		{ value: '3', label: '日本' },
		{ value: '4', label: '韩国' },
		{ value: '5', label: '英国' },
		{ value: '6', label: '德国' },
		{ value: '7', label: '法国' },
		{ value: '8', label: '澳大利亚' },
		{ value: '9', label: '加拿大' },
		{ value: '10', label: '新加坡' },
		{ value: '11', label: '马来西亚' },
		{ value: '12', label: '泰国' }
	])
	
	// 显示选中的国家/地区标签
	const selectedCountryLabel = computed(() => {
		if (!selectedCountry.value) return ''
		const item = countryOptions.value.find(opt => opt.value === selectedCountry.value)
		return item ? item.label : ''
	})
	
	// 打开国家/地区选择弹窗
	const openSelectCountry = () => {
		showCountryPopup.value = true
	}
	
	// 国家/地区选择变化
	const onCountryChange = (value: string | number | null, item: any) => {
		console.log('选中国家/地区:', value, item)
		showCountryPopup.value = false
		uni.showToast({
			title: `已选择：${item.label}`,
			icon: 'success'
		})
	}
	
	// 关闭弹窗时重置搜索
	const onPopupClose = () => {
		showCountryPopup.value = false
		if (searchSelectRef.value) {
			searchSelectRef.value.resetSearch()
		}
	}
	
	// 扫码
	const handleScan = () => {
		uni.navigateTo({
			url: '/pages/scanCode/scanCode'
		})
	}
	
	// 查询缴费
	const handleQuery = () => {
		if (!cardNumber.value) {
			uni.showToast({
				title: '请输入卡号',
				icon: 'none'
			})
			return
		}
		if (!selectedCountry.value) {
			uni.showToast({
				title: '请选择国家/地区',
				icon: 'none'
			})
			return
		}
		console.log('查询卡号:', cardNumber.value)
		console.log('国家/地区:', selectedCountryLabel.value)
		uni.showToast({
			title: '查询中...',
			icon: 'loading'
		})
		// 跳转到充值页面
		// uni.navigateTo({
		// 	url: `/pages/recharge/recharge?cardNo=${cardNumber.value}&country=${selectedCountry.value}`
		// })
	}
	
	// 监听扫码结果
	const onScanResult = (data: UTSJSONObject) => {
		const result = data.getString('result') ?? ''
		if (result.length > 0) {
			cardNumber.value = result
			uni.showToast({
				title: '扫码成功',
				icon: 'success'
			})
		}
	}
	
	onMounted(() => {
		uni.$on('scanResult', onScanResult)
	})
	
	onUnmounted(() => {
		uni.$off('scanResult', onScanResult)
	})
</script>

