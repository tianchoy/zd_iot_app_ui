				}
			}
		}
		
		.order-list {
			flex: 1;
			padding: 24rpx 24rpx 40rpx 24rpx;
			min-height: 700rpx;
			
			.empty-state {
				display: flex;
				justify-content: center;
				align-items: center;
				padding-top: 200rpx;
				
				.empty-text {
					font-size: 28rpx;
					color: #999999;
				}
			}
			
			.orders-container {
				.order-card {
					background-color: #ffffff;
					border-radius: 24rpx;
					padding: 28rpx;
					margin-bottom: 24rpx;
					box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
					
					.order-header {
						display: flex;
						flex-direction: row;
						justify-content: space-between;
						align-items: center;
						padding-bottom: 20rpx;
						border-bottom: 1rpx solid #f0f2f6;
