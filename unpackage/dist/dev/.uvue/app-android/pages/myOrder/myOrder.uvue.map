<template>
	<topNavBar title="我的订单" :show-back="true" @back="handleBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<view class="card-box">
			<!-- 搜索框区域 -->
			<view class="search-value">
				<input
					v-model="card_number"
					placeholder="请输入订单号/卡号"
					class="search-input"
				/>
				<rice-button class="scan-btn" height="100%" @click="scanCode" icon="scan"></rice-button>
				<rice-button type="primary" color="#1989fa" textColor="#ffffff" height="100%" @click="handleQuery">查询</rice-button>
			</view>
			<rice-tabs
				v-model="current"
				line-color="#ffffff" 
				:list="tabs" 
				:line-width="0" 
				:title-active-color="'#2563eb'" 
				:title-inactive-color="'#334155'"
				@change="handleTabClick" 
				:customStyle="{height:'85rpx',padding:'10rpx',border:'1rpx solid #e5edf6'}"
			>
			</rice-tabs>
		</view>
		
		<!-- 订单列表 -->
		<scroll-view class="order-list" scroll-y :enhanced="true" :show-scrollbar="false">
			<view v-if="orderList.length === 0" class="empty-state">
				<text class="empty-text">暂无订单</text>
			</view>
			<view v-else class="orders-container">
				<view 
					v-for="(order, index) in orderList" 
					:key="index"
					class="order-card"
					@click="handleOrderClick(order)"
				>
					<!-- 订单头部：套餐名称和状态 -->
					<view class="order-header">
						<text class="package-name" v-if="order.pkgName">{{ order.pkgName || '套餐名称' }}</text>
						<rice-tag v-if="order.status" :text="getStatusText(order.status) " :round="true" plain-fill size="small" :type="getStatusClass(order.status)"></rice-tag>
					</view>
					
					<!-- 订单详情 -->
					<view class="order-details">
						<view class="detail-row" v-if="order.orderNo">
							<text class="detail-label">订单号</text>
							<text class="detail-value">{{ order.orderNo || '-' }}</text>
						</view>
						<view class="detail-row" v-if="order.cardNo">
							<text class="detail-label">卡号</text>
							<text class="detail-value">{{ order.cardNo || '-' }}</text>
						</view>
						<view class="detail-row" v-if="order.id">
							<text class="detail-label">订单Id</text>
							<text class="detail-value">{{ order.id || '-' }}</text>
						</view>
						<view class="detail-row last">
							<text class="detail-value">{{ order.createTime || '-' }}</text>
							<view class="order-footer">
								<text class="price">¥{{ order.payCurrencyAmount || '0.00' }}</text>
								<text v-if="order.status === '0'" class="pay-btn" @click.stop="handlePay(order)">去支付</text>
							</view>
						</view>
					</view>
					
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
	import {queryOrderList} from '@/api/http'
	import type {OrderListXcxItem} from '@/api/types'
	import { ref, computed, onMounted } from 'vue'
	import {isWechat,isH5} from '@/common/config.uts'
	
	// 订单状态映射
	type OrderStatus = '全部' | '待支付' | '已完成' | '已退款' | '已取消'
	
	// Tab 列表
	type OrderStatusTab = {
		name: OrderStatus,
		value: string
	}
	const tabs = ref<OrderStatusTab[]>([
		{name: '全部',value: ''}, 
		{name: '待支付',value: '0'}, 
		{name: '已完成',value: '1'}, 
		{name: '已退款',value: '5'}, 
		{name: '已取消',value: '2'}
	])
	const current = ref<number>(0)
	const card_number = ref<string>('')
	
	// 订单数据
	const orderList = ref<OrderListXcxItem[]>([])
	
	// 查询状态标志
	const isSearching = ref<boolean>(false)
	
	// 状态码映射
	const getStatusText = (status: string): string => {
		switch (status) {
			case '0':
				return '待支付'
			case '1':
				return '已完成'
			case '2':
				return '已取消'
			case '3':
				return '支付失败'
			case '4':
				return '部分退款'
			case '5':
				return '全部退款'
			default:
				return '未知状态'
		}
	}
	
	// 获取状态对应的tab索引
	const getTabIndexByStatus = (status: string): number => {
		if (status === '' || status === null) {
			return 0 // 全部
		}
		const tabMap = new Map<string, number>()
		tabMap.set('0', 1) // 待支付
		tabMap.set('1', 2) // 已完成
		tabMap.set('5', 3) // 已退款
		tabMap.set('2', 4) // 已取消
		return tabMap.get(status) ?? 0
	}

	// 获取订单列表
	const getOrderList = async (status: string, isSearch: boolean) => {
		try {
			const params: UTSJSONObject = {}
			if (status !== '') {
				params['status'] = status
			}
			// 只有查询操作才传递查询参数
			if (isSearch && card_number.value.trim()) {
				params['rechargeNoAndOrderNo'] = card_number.value.trim()
			}
			const resp = await queryOrderList(params)
			if (resp.code == 200) {
				const rows = resp.rows as OrderListXcxItem[]
				let data: OrderListXcxItem[] = []
				if (rows != null && Array.isArray(rows)) {
					data = rows
				} else {
					data = []
				}

				// 如果是查询操作
				if (isSearch) {
					if (data.length === 0) {
						orderList.value = []
						uni.showToast({
							title: '未找到匹配的订单',
							icon: 'none'
						})
						return
					}

					// 统计各状态的订单数量
					const statusCount = new Map<string, number>()
					let firstStatus = ''
					data.forEach(order => {
						const statusKey = order.status || ''
						const count = statusCount.get(statusKey) ?? 0
						statusCount.set(statusKey, count + 1)
						if (firstStatus === '') {
							firstStatus = statusKey
						}
					})

					// 直接显示查询结果
					orderList.value = data

					// 如果只有一种状态，切换到对应的tab
					if (statusCount.size === 1) {
						if (firstStatus !== '') {
							const targetIndex = getTabIndexByStatus(firstStatus)
							current.value = targetIndex
						} else {
							current.value = 0
						}
					} else {
						// 多种状态，显示在"全部"
						current.value = 0
					}
				} else {
					// 非查询操作，直接显示数据
					orderList.value = data
				}
			} else {
				orderList.value = []
				uni.showToast({
					title: resp.msg || '获取订单列表失败',
					icon: 'none'
				})
			}
		} catch (error) {
			console.error('获取订单列表失败:', error)
			orderList.value = []
			uni.showToast({
				title: '网络错误，请稍后重试',
				icon: 'none'
			})
		}
	}

	// 处理Tab切换
	const handleTabClick = (e: UTSJSONObject) => {
		console.log(e)
		const index = e.index as number
		current.value = index
		// 切换标签时重置查询状态和搜索框
		isSearching.value = false
		card_number.value = ''
		const status = e.value as string
		if (status != null) {
			getOrderList(status, false)
		}
	}
	
	// 获取状态样式类
	const getStatusClass = (status: string): string => {
		switch (status) {
			case '0':
				return 'success'
			case '1':
				return 'primary'
			case '2':
				return 'warning'
			case '3':
				return 'error'
			case '4':
				return 'error'
			case '5':
				return 'error'
			default:
				return ''
		}
	}
	
	// 处理订单点击
	const handleOrderClick = (order: OrderListXcxItem) => {
		console.log(order)
		uni.navigateTo({
			url: `/pages/orderDetail/orderDetail?orderNo=${order.id}`
		})
	}
	
	// 处理返回
	const handleBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}
	
	const scanCode = () => {
		uni.navigateTo({
			url: '/pages/scanCode/scanCode'
		})
	}
	
	// 查询订单
	const handleQuery = () => {
		const keyword = card_number.value.trim()
		if (!keyword) {
			uni.showToast({
				title: '请输入订单号/卡号',
				icon: 'none'
			})
			return
		}
		// 标记为查询状态
		isSearching.value = true
		getOrderList('', true)
	}
	
	// 接收扫码结果
	const onScanResult = async (data: UTSJSONObject) => {
		const result = data.getString('result') ?? ''
		console.log(result)
		if (result.length > 0) {
			card_number.value = result
			uni.showToast({
				title: '扫码成功',
				icon: 'success'
			})
			// 自动查询
			await handleQuery()
		}
	}
	
	// 去支付
	const handlePay = (order: OrderListXcxItem) => {
		if(isWechat()){
			uni.showToast({
				title: `支付订单 ${order.id}`,
				icon: 'none'
			})
			uni.navigateTo({
				url: `/pages/orderDetail/orderDetail?orderNo=${order.id}`
			})
		}

		if(isH5()){
			uni.showToast({
				title: `支付订单 ${order.orderNo}`,
				icon: 'none'
			})
		}
	}

	onShow(() => {
		// 页面显示时重置所有状态
		isSearching.value = false
		card_number.value = ''
		current.value = 0
		getOrderList('', false)
	})
	
	onMounted(() => {
		uni.$on('scanResult', onScanResult)
	})
	
	onUnload(() => {
		// 移除事件监听
		uni.$off('scanResult', onScanResult)
	})
</script>

