						<view class="card-pkg-box">
							<view class="item" v-for="(item, index) in filteredPackageList" :key="index">
								<view class="item-head"><text class="item-label">{{ item.name }}</text><m-tag :text="item.statusText" :round="true" :plain="true" size="small" :type="item.tagType"></m-tag></view>
								<view class="item-sub-title">生效时间：{{ item.startTime }}</view>
								<view class="item-data">
									<view class="item-data-item"><text class="item-data-label">套餐流量</text><text class="item-data-value">{{ item.totalFlow }}</text></view>
									<view class="item-data-item"><text class="item-data-label">已用流量</text><text class="item-data-value">{{ item.usedFlow }}</text></view>
									<view class="item-data-item"><text class="item-data-label">剩余流量</text><text class="item-data-value">{{ item.leftFlow }}</text></view>
								</view>
							</view>
						</view>
					</view>

