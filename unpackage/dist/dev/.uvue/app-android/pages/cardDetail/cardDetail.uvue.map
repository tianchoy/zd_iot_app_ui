		<topNavBar title="卡片详情" :show-back="true" @back="goBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>

		<view class="fixed-tabs">
			<m-tabs :tabs="tabs" :itemWidth="'auto'" :padding="0" :currentTab="active" @change="changeTab" :unlined="true" :bold="true" :activeBgColor="'#eff6ff'" :activeBorderColor="'#bfdbfe'" />
		</view>

		<view class="container">
			<view class="card-box content-card">
				<view class="card-content">
					<view class="section-title">{{activeName}}</view>

					<view class="section-content" v-if="activeName == '基本信息'">
						<view class="base-info-box">
							<view class="base-info">
								<view class="info-item"><text class="info-label">卡片号</text><text class="info-value">{{card_number}}</text></view>
								<view class="info-item"><text class="info-label">ICCID</text><text class="info-value">89860421123456789012</text></view>
								<view class="info-item"><text class="info-label">IMSI</text><text class="info-value">460011234567890</text></view>
								<view class="info-item"><text class="info-label">最近使用</text><text class="info-value">2026-06-05</text></view>
							</view>
						</view>

						<view class="section-title">套餐状态</view>
						<view class="pkg-content">
							<view class="pkg-item"><text class="pkg-label">当前套餐:</text><text class="pkg-value">车联网月包20G</text></view>
							<view class="pkg-item"><text class="pkg-label">套餐流量:</text><text class="pkg-value">20GB</text></view>
							<view class="pkg-item"><text class="pkg-label">套餐有效期:</text><text class="pkg-value">2026-04-30</text></view>
							<view class="pkg-item">
								<text class="pkg-label">待生效期数:</text>
								<view class="pkg-value"><text>11</text><text class="pkg-icon" @click="showMore"><m-icon v-if="!pkgMore" name="arrow-down-filling" size="20rpx"></m-icon><m-icon v-else name="arrow-up-filling" size="20rpx"></m-icon></text></view>
							</view>
							<view class="pkg-date" v-if="pkgMore"><view class="date-list"><text class="date-label"><text class="date-period">第 1 期</text><text>2026-04-30</text></text><m-tag text="标签" :round="true" :plain="true" size="small" type="primary"></m-tag></view></view>
							<view class="pkg-item"><text class="pkg-label">下期开始时间:</text><text class="pkg-value">2026-04-30</text></view>
							<view class="pkg-item"><text class="pkg-label">当前期次:</text><text class="pkg-value">第 1 期</text></view>
							<view class="pkg-item"><text class="pkg-label">当前期有效期:</text><text class="pkg-value">2026-04-30</text></view>
							<view class="pkg-item"><text class="pkg-label">计费方式:</text><text class="pkg-value">按月计费</text></view>
						</view>

						<view class="section-title">流量使用</view>
						<view class="data-total">
							<view class="total-item"><text class="total-label">本月已用:</text><text class="total-value">11.34GB</text></view>
							<view class="total-item"><text class="total-label">剩余流量:</text><text class="total-value">8.66GB</text></view>
							<view class="total-item"><text class="total-label">总流量:</text><text class="total-value">20GB</text></view>
						</view>
					</view>

