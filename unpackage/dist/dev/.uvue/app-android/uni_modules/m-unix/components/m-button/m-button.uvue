        shape: {
            type: String as unknown as PropType<string>,
            default: 'square'
        },
        plain: {
            type: Boolean,
            default: false
        },
        //link样式，去掉边框，结合plain一起使用
        link: {
            type: Boolean,
            default: false
        },
        disabled: {
            type: Boolean,
            default: false
        },
        //禁用后背景是否为灰色 （非空心button生效）
        disabledGray: {
