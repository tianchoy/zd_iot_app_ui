/**
 * 数据响应类型
 */
export type R<T> = {
    // 状态码
    code: number;
    //提示
    msg: string;
    // 二级状态
    status?: number;
    //是否加密
    isSecurity?: boolean;
    //数据
    data: T;
};
/**
 * 系统主题颜色
 */
export type GlobalColor = {
    primary: string;
    danger: string;
    warning: string;
    success: string;
    blue: string;
};
/**
 * 会员信息
 */
export type StoreMemberVo = {
    token: string;
    id?: number;
    nickname?: string;
    phone?: string;
    avatar?: string;
};
