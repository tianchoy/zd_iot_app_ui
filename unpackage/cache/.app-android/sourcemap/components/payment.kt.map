<template>
	<view class="payment-content">
		<!-- 支付信息区域 -->
		<view class="payment-info">
			<text class="info-title">确认支付信息</text>

			<view class="info-item" v-if="props.cardNumber">
				<text class="item-label">卡号</text>
				<text class="item-value">{{ props.cardNumber }}</text>
			</view>

			<view class="info-item" v-if="props.productName">
				<text class="item-label">商品</text>
				<text class="item-value">{{ props.productName }}</text>
			</view>

			<view class="info-item" v-if="props.traffic">
				<text class="item-label">流量</text>
				<text class="item-value">{{ props.traffic }}</text>
			</view>

			<view class="info-item" v-if="props.validityPeriod">
				<text class="item-label">有效期</text>
				<text class="item-value">{{ props.validityPeriod }}{{ props?.pkgType == '1' ? '天' : '个月' }}</text>
			</view>

			<!-- 支付方式区域：根据平台条件渲染 -->
			<view class="payment-methods">

				<view class="method-section">
					<text class="section-title">选择支付方式</text>
					<view class="method-option" 
							v-for="method in paymentMethods" 
							:key="method.id"
							:class="{ 'method-selected': selectedMethodId === method.id }"
							@click="selectPaymentMethod(method.id)">
						<view class="method-left">
							<text class="method-label">{{ method.label }}</text>
							<text v-if="method.desc" class="method-desc">{{ method.desc }}</text>
						</view>
						<view class="method-right">
							<view :class="['radio', { 'radio-selected': selectedMethodId === method.id }]"></view>
						</view>
					</view>
				</view>

			</view>

			<view class="info-item">
				<text class="item-label">应付金额</text>
				<text class="item-value amount">{{ formattedAmount }}</text>
			</view>
		</view>

		<!-- 提示信息 -->
		<view class="tips">
			<text class="tips-text">续费后套餐将在30分钟内生效，如续费后设备始终无法上线，请您联系客服处理！</text>
		</view>

		<!-- 按钮区域 -->
		<view class="action-buttons">
			<rice-button class="btn cancel-btn mr-24" @click="handleCancel">取消</rice-button>
			<rice-button class="btn confirm-btn ml-24" textColor="#fff" @click="handleConfirm">确认支付</rice-button>
		</view>
	</view>
</template>

<script setup lang="uts">
// 定义组件属性 (props)
const props = defineProps<{
	// 卡号（可选，有默认值）
	cardNumber?: string;
	// 商品名称（可选，有默认值）
	productName?: string;
	// 流量大小（可选，有默认值）
	traffic?: string;
	// 有效期描述（可选，有默认值）
	validityPeriod?: string;
	// 应付金额
	amount: string | number;
	pkgType?: string;
}>();


// 定义组件事件
const emit = defineEmits<{
	(e: 'cancel'): void;
	(e: 'confirm', paymentMethodId: string): void;
}>();

// 获取格式化后的金额显示
const formattedAmount = computed(() => {
	return `￥${props.amount}`;
});

type PaymentMethod = {
	id: string
	label: string
	desc?: string
}

const paymentMethods = ref<PaymentMethod[]>([
	{ id: 'wechat_h5', label: '微信H5支付', desc: '推荐使用微信完成支付' },
	{ id: 'alipay', label: '支付宝支付', desc: '通过支付宝完成支付' },
	{ id: 'bank_card', label: '银行卡支付', desc: '支持常见银行卡支付' }
]);

// 当前选中的支付方式ID
const selectedMethodId = ref<string>('wechat_h5'); // 默认选中微信H5支付

// 选择支付方式
const selectPaymentMethod = (methodId: string) => {
	selectedMethodId.value = methodId;
};

// --- 事件处理 ---
const handleCancel = () => {
	emit('cancel');
};

const handleConfirm = () => {






	// H5等环境：使用当前选中的支付方式
	emit('confirm', selectedMethodId.value);

};
</script>

