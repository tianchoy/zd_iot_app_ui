<template>
	<topNavBar title="жҲ‘зҡ„еҘ—йӨҗ" :show-back="true" @back="goBack" backgroundColor="#f4f7fb" textColor="#333" :showCapsule="false"></topNavBar>
	<view class="container">
		<view class="card-info">
			<view class="info-title">еҪ“еүҚеҚЎеҸ·</view>
			<view class="info-value">1064916585160</view>
		</view>
		<view class="pkg-box">
			<m-segmented-control 
				:values="pkgTabs" 
				:current="current" 
				:textActiveColor="'#2563eb'" 
				@click="handleClick" 
				:customStyle="{height:'unset',padding:'5rpx 10rpx',border:'1rpx solid #e5edf6'}" 
			/>
			<!-- еҘ—йӨҗеҲ—иЎЁ -->
		<scroll-view class="package-list" scroll-y :enhanced="true">
			<view v-if="filteredPackages.length === 0" class="empty-state">
				<text class="empty-text">жҡӮж— еҘ—йӨҗ</text>
			</view>
			<view 
				v-for="(item, index) in filteredPackages" 
				:key="index"
				class="package-card"
			>
				<!-- еҘ—йӨҗеӨҙйғЁ -->
				<view class="package-header">
					<text class="package-name">{{ item.name }}</text>
					<text class="status-tag" :class="getStatusClass(item.status)">{{ item.status }}</text>
				</view>
				
				<!-- з”ҹж•Ҳж—¶й—ҙ -->
				<view class="effective-time">
					<text class="time-label">з”ҹж•Ҳж—¶й—ҙпјҡ</text>
					<text class="time-value">{{ item.effectiveTime }}</text>
				</view>
				
				<!-- еҘ—йӨҗж•°жҚ®жҢҮж Ү -->
				<view class="package-metrics">
					<view class="metric-item">
						<text class="metric-label">жөҒйҮҸ</text>
						<text class="metric-value">{{ item.totalTraffic }}</text>
					</view>
					<view class="metric-item">
						<text class="metric-label">еү©дҪҷ</text>
						<text class="metric-value">{{ item.remainingTraffic }}</text>
					</view>
					<view class="metric-item">
						<text class="metric-label">еҲ°жңҹ</text>
						<text class="metric-value">{{ item.expireDate }}</text>
					</view>
				</view>
			</view>
		</scroll-view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, computed } from 'vue'
	
	// еҘ—йӨҗзҠ¶жҖҒзұ»еһӢ
	type PackageStatus = 'е…ЁйғЁ' | 'еңЁз”ЁеҘ—йӨҗ' | 'еҫ…з”ҹж•Ҳ' | 'е·ІеӨұж•Ҳ'
	
	// еҘ—йӨҗж•°жҚ®з»“жһ„
	interface PackageItem {
		name: string
		status: Exclude<PackageStatus, 'е…ЁйғЁ'>
		effectiveTime: string
		totalTraffic: string
		remainingTraffic: string
		expireDate: string
	}
	
	// Tab еҲ—иЎЁ
	const pkgTabs = ref<PackageStatus[]>(['е…ЁйғЁ', 'еңЁз”ЁеҘ—йӨҗ', 'еҫ…з”ҹж•Ҳ', 'е·ІеӨұж•Ҳ'])
	const current = ref<number>(0)
	
	// еҘ—йӨҗж•°жҚ®
	const packageList = ref<PackageItem[]>([
		{
			name: 'иҪҰиҒ”зҪ‘жңҲеҢ…20G',
			status: 'еңЁз”ЁеҘ—йӨҗ',
			effectiveTime: '2026-04-01',
			totalTraffic: '20GB',
			remainingTraffic: '8.66GB',
			expireDate: '2026-04-30'
		},
		{
			name: 'иҪҰиҒ”зҪ‘жңҲеҢ…10G',
			status: 'еҫ…з”ҹж•Ҳ',
			effectiveTime: 'еҫ…з”ҹж•Ҳ',
			totalTraffic: '10GB',
			remainingTraffic: '10GB',
			expireDate: '2026-05-30'
		},
		{
			name: 'е·Ҙдёҡи®ҫеӨҮжңҲеҢ…5G',
			status: 'еҫ…з”ҹж•Ҳ',
			effectiveTime: 'еҫ…з”ҹж•Ҳ',
			totalTraffic: '5GB',
			remainingTraffic: '5GB',
			expireDate: '2026-06-30'
		},
		{
			name: 'жөӢиҜ•еҘ—йӨҗ1G',
			status: 'е·ІеӨұж•Ҳ',
			effectiveTime: '2026-03-01',
			totalTraffic: '1GB',
			remainingTraffic: '0',
			expireDate: '2026-03-31'
		}
	])
	
	// ж №жҚ® Tab зӯӣйҖүеҘ—йӨҗ
	const filteredPackages = computed(() => {
		const currentStatus = pkgTabs.value[current.value]
		if (currentStatus === 'е…ЁйғЁ') {
			return packageList.value
		}
		return packageList.value.filter(item => item.status === currentStatus)
	})
	
	// Tab еҲҮжҚўеӨ„зҗҶ
	const handleClick = (e: UTSJSONObject) => {
		current.value = e.index as number
	}
	
	// иҺ·еҸ–зҠ¶жҖҒж ·ејҸзұ»
	const getStatusClass = (status: string): string => {
		switch (status) {
			case 'еңЁз”ЁеҘ—йӨҗ':
				return 'status-active'
			case 'еҫ…з”ҹж•Ҳ':
				return 'status-pending'
			case 'е·ІеӨұж•Ҳ':
				return 'status-expired'
			default:
				return ''
		}
	}

	// иҝ”еӣһдёҠдёҖйЎө
	const goBack = () => {
		uni.navigateBack({
			delta: 1
		})
	}
		
</script>

