					margin-bottom: 12rpx;
				}
			}
			.card-bottom{
				display: flex;
				flex-direction: row;
				align-items: center;
				justify-content: space-between;
				margin-top: 24rpx;
				.btn{
					flex: 1;
				}
			}
		}
		.pkg-box{
			background: #ffffff;
			border: 1rpx solid #e7edf5;
