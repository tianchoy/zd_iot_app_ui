				flex: 1;
				.pkg-name {
					display: flex;
					flex-direction: row;
					align-items: center;
					margin-bottom: 12rpx;
					flex-wrap: wrap;
					.pkg-title {
						font-size: 30rpx;
						font-weight: bold;
						color: #1e293b;
					}
					.pkg-tag {
						background: linear-gradient(135deg, #ff9a3c, #ff6b3c);
						color: #ffffff;
						font-size: 20rpx;
						padding: 4rpx 16rpx;
						border-radius: 20rpx;
						margin-left: 12rpx;
					}
				}
				.pkg-desc {
					display: flex;
					flex-direction: row;
					font-size: 24rpx;
					color: #64748b;
					.pkg-icon{
						display: flex;
						align-items: center;
						padding: 10rpx 20rpx;
						border-radius: 24rpx;
						background: #f8fafc;
