om(min, max) {\n    return Math.floor(Math.random() * (max - min + 1)) + min;\n}\n// 判断类型\nexport function isObject(value = null) {\n    return typeof value === 'object' && value !== null;\n}\nexport function isArray(value = null) {\n    return Array.isArray(value);\n}\nexport function isFunction(value = null) {\n    return typeof value === 'function';\n}\n//# sourceMappingURL=/Users/xyhc/Documents/zd_iot_app_ui/uni_modules/m-unix/libs/utils.uts.js.map","references":[],"utsMeta":{},"map":"{\"version\":3,\"file\":\"utils.uts.js\",\"sourceRoot\":\"\",\"sources\":[\"utils.uts\"],\"names\":[],\"mappings\":\";AAAA,QAAQ;AACR,MAAM,UAAU,UAAU,CAAC,IAAmB,EAAE,SAAiB,qBAAqB;IACrF,IAAI,CAAO,CAAA;IACX,IAAI,OAAO,IAAI,KAAK,QAAQ,EAAE;QAC7B,CAAC,GAAG,IAAI,IAAI,CAAC,IAAI,CAAC,CAAA;KAClB;SAAM;QACN,CAAC,GAAG,IAAI,CAAA;KACR;IACD,MAAM,IAAI,GAAG,CAAC,CAAC,WAAW,EAAE,CAAA;IAC5B,MAAM,KAAK,GAAG,OAAO,CAAC,CAAC,CAAC,QAAQ,EAAE,GAAG,CAAC,CAAC,CAAA;IACvC,MAAM,GAAG,GAAG,OAAO,CAAC,CAAC,CAAC,OAAO,EAAE,CAAC,CAAA;IAChC,MAAM,IAAI,GAAG,OAAO,CAAC,CAAC,CAAC,QAAQ,EAAE,CAAC,CAAA;IAClC,MAAM,MAAM,GAAG,OAAO,CAAC,CAAC,CAAC,UAAU,EAAE,CAAC,CAAA;IACtC,MAAM,MAAM,GAAG,OAAO,CAAC,CAAC,CAAC,UAAU,EAAE,CAAC,CAAA;IAEtC,IAAI,MAAM,GAAG,MAAM,CAAA;IACnB,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,MAAM,EAAE,MAAM,CAAC,IAAI,CAAC,CAAC,CAAA;IAC7C,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,IAAI,EAAE,KAAK,CAAC,CAAA;IACpC,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,IAAI,EAAE,GAAG,CAAC,CAAA;IAClC,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,IAAI,EAAE,IAAI,CAAC,CAAA;IACnC,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,IAAI,EAAE,MAAM,CAAC,CAAA;IACrC,MAAM,GAAG,MAAM,CAAC,OAAO,CAAC,IAAI,EAAE,MAAM,CAAC,CAAA;IACrC,OAAO,MAAM,CAAA;AACd,CAAC;AAED,KAAK;AACL,MAAM,UAAU,OAAO,CAAC,GAAW;IAClC,OAAO,GAAG,GAAG,EAAE,CAAC,CAAC,CAAC,GAAG,GAAG,GAAG,CAAC,CAAC,CAAC,MAAM,CAAC,GAAG,CAAC,CAAA;AAC1C,CAAC;AAED,KAAK;AACL,MAAM,UAAU,QAAQ,CAAC,IAAc,EAAE,OAAe,GAAG;IAC1D,IAAI,OAAO,GAAkB,IAAI,CAAA;IACjC,OAAO,UAAoB,GAAG,IAAW;QACxC,IAAI,OAAO,EAAE;YACZ,YAAY,CAAC,OAAO,CAAC,CAAA;SACrB;QACD,OAAO,GAAG,UAAU,CAAC;YACpB,IAAI,CAAC,KAAK,CAAC,IAAI,EAAE,IAAI